<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.AlarmBySeverityWidget"
             x:Name="RootWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             Height="250" Width="400">

    <Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0">
        <Border.BorderBrush>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.BorderBrush>

        <Grid>
            <Border Background="#3E3E42"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,0,0,1"
                    Height="25"
                    VerticalAlignment="Top"
                    Padding="10,0,0,0"
                    CornerRadius="6,6,0,0">
                <TextBlock Text="Alarms by Severity"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Border>

            <Button x:Name="DeleteButton"
                    Content="X"
                    Width="30" Height="23"
                    MinWidth="0" MinHeight="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    FontSize="16"
                    Background="Transparent"
                    Foreground="#888888"
                    BorderThickness="0"
                    Cursor="Hand"
                    Click="DeleteWidget_Click"/>

            <lvc:PieChart Grid.Row="1" Series="{Binding ChartSeries, ElementName=RootWidget}" 
                          InnerRadius="60" LegendLocation="None" Hoverable="True"
                          DataTooltip="{x:Null}"
                          DataHover="Chart_DataHover"
                          MouseLeave="Chart_MouseLeave"
                          Margin="10,40,10,10">
            </lvc:PieChart>

            <Popup x:Name="HoverPopup" AllowsTransparency="True" Placement="Mouse" IsHitTestVisible="False">
                <Border Background="#2A2B31" BorderBrush="#444444" BorderThickness="1" CornerRadius="4" Padding="10">
                    <TextBlock x:Name="HoverText" Foreground="White" FontSize="14" FontWeight="Medium"/>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>