<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.AlarmBySeverityWidget"
             x:Name="RootWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             Tag="3x3"
             Width="Auto" Height="Auto"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid Margin="5,5,0,0">
        <Border x:Name="MainBorder"
                Background="{DynamicResource BgMain}"
                BorderThickness="1"
                CornerRadius="6">

            <Border.BorderBrush>
                <VisualBrush Stretch="None">
                    <VisualBrush.Visual>
                        <Rectangle Stroke="#E8751A"
                                   StrokeDashArray="4 2"
                                   StrokeThickness="1"
                                   RadiusX="6" RadiusY="6"
                                   Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
                                   Height="{Binding ElementName=MainBorder, Path=ActualHeight}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="{DynamicResource BgMain}">
                    <TextBlock Text="Alarms by Severity"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <Button x:Name="DeleteButton" 
                            Content="X" 
                            Width="20" Height="20" 
                            MinWidth="20" MinHeight="20"
                            MaxWidth="20" MaxHeight="20"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top" 
                            Margin="0,3,3,0"
                            Padding="0"
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextPrimary}"
                            Background="{DynamicResource ButtonBg}"
                            BorderThickness="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="DeleteWidget_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="2"/>
                            </Style>
                        </Button.Resources>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder"
                                        Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                    </Trigger>
                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <Grid Grid.Row="1" Margin="5,10,10,15">

                    <Viewbox Stretch="Uniform" Margin="10" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel Width="220">
                            <lvc:PieChart Series="{Binding ChartSeries, ElementName=RootWidget}" 
                                InnerRadius="25" 
                                LegendLocation="None" 
                                Hoverable="True"
                                DataTooltip="{x:Null}"
                                DataHover="Chart_DataHover"
                                MouseLeave="Chart_MouseLeave"
                                Margin="10,5,10,5">
                            </lvc:PieChart>
                        </StackPanel>
                    </Viewbox>

                    <Popup x:Name="HoverPopup" AllowsTransparency="True" Placement="Mouse" IsHitTestVisible="False">
                        <Border Background="{DynamicResource BgMain}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="4" Padding="10">
                            <TextBlock x:Name="HoverText" Foreground="{DynamicResource TextPrimary}" FontSize="14" FontWeight="Medium"/>
                        </Border>
                    </Popup>

                    <Thumb x:Name="InternalResizeThumb"
                           Width="12"
                           Height="12"
                           Cursor="SizeNWSE"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Right"
                           Background="Transparent">
                        <Thumb.Template>
                            <ControlTemplate>
                                <Path Data="M 12,0 L 12,12 L 0,12 Z"
                                      Fill="#888"
                                      Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>