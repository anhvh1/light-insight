<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.AlarmDailyCountWidget"
             x:Name="RootWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LightInsight.Dashboard.AlarmsAndEvents"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             mc:Ignorable="d" 
             d:DesignHeight="350" d:DesignWidth="700">

    <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="5" Padding="15">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Alarms Daily Count" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>

                <Button Grid.Column="1" x:Name="DeleteButton" Content="✕" Width="20" Height="20" FontSize="12" Padding="0"
                        Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand"
                        VerticalAlignment="Center" Click="DeleteWidget_Click" Margin="10,0,0,0"/>
            </Grid>

            <lvc:CartesianChart x:Name="DailyChart" Grid.Row="1" Margin="10,0,10,0"
                                Hoverable="False" 
                                DataTooltip="{x:Null}"
                                DataHover="Chart_DataHover"
                                MouseLeave="Chart_MouseLeave">

                <lvc:CartesianChart.AxisX>
                    <lvc:Axis x:Name="DailyAxisX" Foreground="#888888" FontSize="12">
                        <lvc:Axis.Separator>
                            <lvc:Separator Step="1" Stroke="Transparent" />
                        </lvc:Axis.Separator>
                    </lvc:Axis>
                </lvc:CartesianChart.AxisX>

                <lvc:CartesianChart.AxisY>
                    <lvc:Axis MinValue="0" MaxValue="60" Foreground="#888888" FontSize="12">
                        <lvc:Axis.Separator>
                            <lvc:Separator Stroke="#333333" StrokeThickness="1" StrokeDashArray="4" />
                        </lvc:Axis.Separator>
                    </lvc:Axis>
                </lvc:CartesianChart.AxisY>
            </lvc:CartesianChart>

            <Popup x:Name="HoverPopup" AllowsTransparency="True" Placement="Mouse" IsHitTestVisible="False">
                <Border Background="#2A2B31" BorderBrush="#444444" BorderThickness="1" CornerRadius="4" Padding="12">
                    <StackPanel>
                        <TextBlock x:Name="TooltipDay" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0,0,0,5"/>
                        <TextBlock x:Name="TooltipCount" Foreground="#E87E14" FontSize="13"/>
                    </StackPanel>
                </Border>
            </Popup>
        </Grid>
    </Border>
</UserControl>