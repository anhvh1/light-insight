<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.AlarmSLABreachWidget"
             x:Name="RootWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Tag="2x2"
             Width="Auto" Height="Auto"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid Margin="5,5,0,0">
        <Border x:Name="MainBorder"
                Background="{DynamicResource BgMain}"
                BorderThickness="1"
                CornerRadius="6">

            <!-- DASH BORDER -->
            <Border.BorderBrush>
                <VisualBrush Stretch="None">
                    <VisualBrush.Visual>
                        <Rectangle Stroke="#E8751A"
                                   StrokeDashArray="4 2"
                                   StrokeThickness="1"
                                   RadiusX="6" RadiusY="6"
                                   Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
                                   Height="{Binding ElementName=MainBorder, Path=ActualHeight}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Background="{DynamicResource BgMain}">
                    <TextBlock Text="Alarm SLA Breach"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <Button x:Name="DeleteButton" 
                            Content="X" 
                            Width="20" Height="20" 
                            MinWidth="20" MinHeight="20"
                            MaxWidth="20" MaxHeight="20"
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Top" 
                            Margin="0,3,3,0"
                            Padding="0"
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{DynamicResource TextPrimary}"
                            Background="{DynamicResource ButtonBg}"
                            BorderThickness="0"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Click="DeleteWidget_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="2"/>
                            </Style>
                        </Button.Resources>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder"
                                        Background="{TemplateBinding Background}" 
                                        BorderBrush="{TemplateBinding BorderBrush}" 
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- CONTENT -->
                <Grid Grid.Row="1" Margin="10">

                    <!-- 🔥 Dùng Viewbox để scale toàn bộ UI -->
                    <Viewbox Stretch="Uniform">
                        <StackPanel Width="200">

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="M0,12 L5,12 L8,2 L12,22 L15,12 L20,12"
                                      Stroke="#FF6B6B"
                                      StrokeThickness="2.5"
                                      Width="24" Height="24"
                                      Margin="0,0,10,0"/>

                                <TextBlock x:Name="CountText"
                                           Text="3"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#FF6B6B"/>
                            </StackPanel>

                            <TextBlock Text="SLA Breaches"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="16"
                                       Margin="0,5,0,5"/>

                            <StackPanel Orientation="Horizontal">
                                <Path Data="M2,14 L8,8 L12,12 L18,4 M14,4 L18,4 L18,8"
                                      Stroke="#2ECC71"
                                      StrokeThickness="2"
                                      Width="12" Height="12"
                                      Margin="0,0,6,0"/>

                                <TextBlock x:Name="TrendText"
                                           Text="25% vs last period"
                                           Foreground="#2ECC71"
                                           FontSize="12"/>
                            </StackPanel>

                        </StackPanel>
                    </Viewbox>

                    <!-- RESIZE -->
                    <Thumb x:Name="InternalResizeThumb"
                           Width="12"
                           Height="12"
                           Cursor="SizeNWSE"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Right"
                           Background="Transparent">
                        <Thumb.Template>
                            <ControlTemplate>
                                <Path Data="M 12,0 L 12,12 L 0,12 Z"
                                      Fill="#888"
                                      Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>