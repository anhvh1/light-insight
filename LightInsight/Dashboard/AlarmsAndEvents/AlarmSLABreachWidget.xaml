<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.AlarmSLABreachWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             Height="150" Width="300">

    <Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0">
        <Border.BorderBrush>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.BorderBrush>

        <Grid>
            <Border Background="#3E3E42"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,0,0,1"
                    Height="25"
                    VerticalAlignment="Top"
                    Padding="10,0,0,0"
                    CornerRadius="6,6,0,0">
                <TextBlock Text="Alarm SLA Breach"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Border>

            <Button x:Name="DeleteButton"
                    Content="X"
                    Width="30" Height="23"
                    MinWidth="0" MinHeight="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    FontSize="16"
                    Click="DeleteWidget_Click"/>

            <StackPanel Margin="4 40 0 0">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M0,12 L5,12 L8,2 L12,22 L15,12 L20,12" 
                          Stroke="#FF6B6B" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                          Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" Margin="0 0 10 0"/>

                    <TextBlock x:Name="CountText" Text="3"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#FF6B6B"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="SLA Breaches"
                           Foreground="LightGray"
                           FontSize="16"/>

                <StackPanel Orientation="Horizontal">
                    <Path Data="M2,14 L8,8 L12,12 L18,4 M14,4 L18,4 L18,8" 
                          Stroke="#2ECC71" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                          Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0 0 6 0"/>

                    <TextBlock x:Name="TrendText" Text="25% vs last period"
                               Foreground="#2ECC71" 
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>