<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.AlarmSLABreachWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LightInsight.Dashboard.AlarmsAndEvents"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800"
             HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch"
             MinHeight="100" MinWidth="300">

    <Border Background="#2D2D30" BorderThickness="1" CornerRadius="6" Padding="15">
        <Border.BorderBrush>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Rectangle Stroke="#E8751A" StrokeDashArray="4 2" StrokeThickness="1" RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.BorderBrush>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Alarm SLA Breach" Foreground="White" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center"/>

                <Button Grid.Column="1" x:Name="DeleteButton" Content="✕" Width="20" Height="20" FontSize="12" Padding="0"
                        Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand"
                        VerticalAlignment="Center" Click="DeleteWidget_Click" Margin="10,0,0,0" MinWidth="0" MinHeight="0"/>
            </Grid>

            <StackPanel Grid.Row="1" VerticalAlignment="Center" Margin="5,0,0,0">

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Path Data="M0,12 L5,12 L8,2 L12,22 L15,12 L20,12" 
                          Stroke="#FF6B6B" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                          Width="26" Height="26" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,12,0"/>

                    <TextBlock x:Name="CountText" Text="3" Foreground="#FF6B6B" FontSize="42" FontWeight="Bold" VerticalAlignment="Center" Margin="0,-5,0,0"/>
                </StackPanel>

                <TextBlock Text="SLA Breaches" Foreground="#AAAAAA" FontSize="16" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <Path Data="M2,14 L8,8 L12,12 L18,4 M14,4 L18,4 L18,8" 
                          Stroke="#2ECC71" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                          Width="16" Height="16" Stretch="Uniform" VerticalAlignment="Center" Margin="0,0,6,0"/>

                    <TextBlock x:Name="TrendText" Text="25% vs last period" Foreground="#2ECC71" FontSize="14" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
