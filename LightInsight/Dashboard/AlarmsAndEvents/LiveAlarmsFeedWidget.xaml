<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.LiveAlarmsFeedWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LightInsight.Dashboard.AlarmsAndEvents"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="320">

    <Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Padding="15">
        <Border.BorderBrush>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.BorderBrush>
        
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,15">
                <TextBlock Text="Live Alarms Feed" Foreground="White" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">

                    <Button x:Name="DeleteButton" Content="X" Width="15" Height="15" FontSize="10" Padding="0"
                            Background="Transparent" Foreground="#888888" BorderThickness="0" Cursor="Hand"
                            VerticalAlignment="Center" Click="DeleteWidget_Click" MinWidth="0" MinHeight="0"/>
                </StackPanel>
            </Grid>

            <ScrollViewer Grid.Row="1" MaxHeight="380" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                <ItemsControl ItemsSource="{Binding}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border BorderBrush="{Binding BottomLineColor}" BorderThickness="0,0,0,1" Padding="0,12">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Cursor" Value="Hand"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#2C2D35"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Border Grid.Column="0" Width="2" Background="{Binding PriorityColor}" Margin="0,2,8,2" CornerRadius="1"/>
                                    <Ellipse Grid.Column="1" Width="8" Height="8" Fill="{Binding IndicatorColor}" VerticalAlignment="Top" Margin="5,5,10,0"/>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                            <TextBlock Text="{Binding Location}" Foreground="White" FontWeight="Medium" FontSize="13"/>
                                            <TextBlock Text="{Binding EventType}" Foreground="#777777" FontSize="12" Margin="6,1,0,0"/>
                                        </StackPanel>
                                        <TextBlock Text="{Binding IdAndTime}" Foreground="#555555" FontSize="11"/>
                                    </StackPanel>

                                    <Border Grid.Column="3" Background="{Binding BadgeBgColor}" CornerRadius="4" Padding="12,4" VerticalAlignment="Center" Margin="10,0,5,0">
                                        <TextBlock Text="{Binding Status}" Foreground="{Binding BadgeTextColor}" FontSize="11" FontWeight="Medium"/>
                                    </Border>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>