<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.LiveAlarmsFeedWidget"
             x:Name="RootWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Tag="3x4"
             Width="Auto" Height="Auto"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid Margin="5,5,0,0">
        <Border x:Name="MainBorder"
                Background="{DynamicResource BgMain}"
                BorderThickness="1"
                CornerRadius="6">

            <!-- DASH BORDER -->
            <Border.BorderBrush>
                <VisualBrush Stretch="None">
                    <VisualBrush.Visual>
                        <Rectangle Stroke="#E8751A"
                                   StrokeDashArray="4 2"
                                   StrokeThickness="1"
                                   RadiusX="6" RadiusY="6"
                                   Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
                                   Height="{Binding ElementName=MainBorder, Path=ActualHeight}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Background="{DynamicResource BgMain}">
                    <TextBlock Text="Live Alarms Feed"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <Button x:Name="DeleteButton" 
        Content="X" 
        Width="20" Height="20" 
        MinWidth="20" MinHeight="20"
        MaxWidth="20" MaxHeight="20"
        HorizontalAlignment="Right" 
        VerticalAlignment="Top" 
        Margin="0,3,3,0"
        Padding="0"
        FontSize="12"
        FontWeight="Bold"
        Foreground="{DynamicResource TextPrimary}"
        Background="{DynamicResource ButtonBg}"
        BorderThickness="0"
        HorizontalContentAlignment="Center"
        VerticalContentAlignment="Center"
        Click="DeleteWidget_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="2"/>
                            </Style>
                        </Button.Resources>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder"
                    
                    Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- CONTENT -->
                <Grid Grid.Row="1">

                    <!-- 🔥 ScrollViewer KHÔNG set MaxHeight -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Margin="5">

                        <ItemsControl ItemsSource="{Binding}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border BorderBrush="{Binding BottomLineColor}"
                                            BorderThickness="0,0,0,1"
                                            Padding="0,10">

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <Border Grid.Column="0"
                                                    Width="2"
                                                    Background="{Binding PriorityColor}"
                                                    Margin="0,2,8,2"/>

                                            <Ellipse Grid.Column="1"
                                                     Width="8" Height="8"
                                                     Fill="{Binding IndicatorColor}"
                                                     Margin="5,5,10,0"/>

                                            <StackPanel Grid.Column="2">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding Location}"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               FontSize="13"/>

                                                    <TextBlock Text="{Binding EventType}"
                                                               Foreground="{DynamicResource TextPrimary}"
                                                               FontSize="12"
                                                               Margin="6,1,0,0"/>
                                                </StackPanel>

                                                <TextBlock Text="{Binding IdAndTime}"
                                                           Foreground="{DynamicResource TextPrimary}"
                                                           FontSize="11"/>
                                            </StackPanel>

                                            <Border Grid.Column="3"
                                                    Background="{Binding BadgeBgColor}"
                                                    CornerRadius="4"
                                                    Padding="10,3"
                                                    Margin="10,0,5,0">
                                                <TextBlock Text="{Binding Status}"
                                                           Foreground="{Binding BadgeTextColor}"
                                                           FontSize="11"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- RESIZE -->
                    <Thumb x:Name="InternalResizeThumb"
                           Width="12"
                           Height="12"
                           Cursor="SizeNWSE"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Right"
                           Background="Transparent">
                        <Thumb.Template>
                            <ControlTemplate>
                                <Path Data="M 12,0 L 12,12 L 0,12 Z"
                                      Fill="#888"
                                      Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>