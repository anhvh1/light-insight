<UserControl x:Class="LightInsight.Dashboard.AlarmsAndEvents.AlarmByTypeWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
             Tag="5x3"
             Width="Auto" Height="Auto"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid Margin="5,5,0,0">
        <Border x:Name="MainBorder"
                Background="{DynamicResource BgMain}"
                BorderThickness="1"
                CornerRadius="6">

            <!-- DASH BORDER -->
            <Border.BorderBrush>
                <VisualBrush Stretch="None">
                    <VisualBrush.Visual>
                        <Rectangle Stroke="#E8751A"
                                   StrokeDashArray="4 2"
                                   StrokeThickness="1"
                                   RadiusX="6" RadiusY="6"
                                   Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
                                   Height="{Binding ElementName=MainBorder, Path=ActualHeight}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Background="{DynamicResource BgMain}">
                    <TextBlock Text="{DynamicResource Alarm_Title_ByType}"
                               Foreground="{DynamicResource TextPrimary}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="10,0"/>

                    <Button x:Name="DeleteButton" 
                             Content="X" 
                             Width="20" Height="20" 
                             MinWidth="20" MinHeight="20"
                             MaxWidth="20" MaxHeight="20"
                             HorizontalAlignment="Right" 
                             VerticalAlignment="Top" 
                             Margin="0,3,3,0"
                             Padding="0"
                             FontSize="12"
                             FontWeight="Bold"
                             Foreground="{DynamicResource TextPrimary}"
                             Background="{DynamicResource ButtonBg}"
                             BorderThickness="0"
                             HorizontalContentAlignment="Center"
                             VerticalContentAlignment="Center"
                             Click="DeleteWidget_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="2"/>
                            </Style>
                        </Button.Resources>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder"
                    
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- CONTENT -->
                <Grid Grid.Row="1">

                    <!-- CHART -->
                    <lvc:CartesianChart x:Name="DailyChart"
                                        Margin="10"
                                        Hoverable="True"
                                        DataTooltip="{x:Null}"
                                        DataHover="Chart_DataHover"
                                        MouseLeave="Chart_MouseLeave">

                        <lvc:CartesianChart.AxisX>
                            <lvc:Axis x:Name="DailyAxisX" Foreground="{DynamicResource TextPrimary}" FontSize="12">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Step="1" Stroke="Transparent"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisX>

                        <lvc:CartesianChart.AxisY>
                            <lvc:Axis MinValue="0" Foreground="{DynamicResource TextPrimary}" FontSize="12">
                                <lvc:Axis.Separator>
                                    <lvc:Separator Stroke="#333333"
                                                   StrokeThickness="1"
                                                   StrokeDashArray="4"/>
                                </lvc:Axis.Separator>
                            </lvc:Axis>
                        </lvc:CartesianChart.AxisY>
                    </lvc:CartesianChart>

                    <!-- TOOLTIP -->
                    <Popup x:Name="HoverPopup"
                           AllowsTransparency="True"
                           Placement="Mouse"
                           IsHitTestVisible="False">
                        <Border Background="{DynamicResource BgMain}"
                                BorderBrush="{DynamicResource CardBorder}"
                                BorderThickness="1"
                                CornerRadius="4"
                                Padding="12">
                            <StackPanel>
                                <TextBlock x:Name="TooltipDay"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="14"
                                           FontWeight="Bold"
                                           Margin="0,0,0,5"/>
                                <TextBlock x:Name="TooltipCount"
                                           Foreground="{DynamicResource TextPrimary}"
                                           FontSize="13"/>
                            </StackPanel>
                        </Border>
                    </Popup>

                    <!-- RESIZE -->
                    <Thumb x:Name="InternalResizeThumb"
                           Width="12"
                           Height="12"
                           Cursor="SizeNWSE"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Right"
                           Background="Transparent">
                        <Thumb.Template>
                            <ControlTemplate>
                                <Path Data="M 12,0 L 12,12 L 0,12 Z"
                                      Fill="#888"
                                      Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>