<UserControl x:Class="LightInsight.Dashboard.Dashboard.DashboardView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Background="#1E1E1E">

    <Grid>

        <!-- ================= MAIN LAYOUT ================= -->

        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ================= TOP BAR ================= -->

        <Border Grid.Column="0"
            Grid.ColumnSpan="3"
            Background="#2B2B2B"
            Padding="10">

            <DockPanel LastChildFill="False">
                <!-- LEFT AREA -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- LOGO -->
                    <Border Height="30" Margin="5,0,20,0" CornerRadius="8" Background="Transparent">
                        <Image Source="/LightInsight;component/Dashboard/Asset/logo.png" Stretch="Uniform"/>
                    </Border>
                    <!-- BREADCRUMB -->
                    <TextBlock x:Name="BreadcrumbText" Text="Dashboard" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                </StackPanel>
                <!-- RIGHT AREA -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <!-- EDIT LAYOUT -->
                    <Button x:Name="EditLayoutBtn" Content="Edit Layout" Width="90" Margin="5" Click="EditLayoutBtn_Click" Background="Orange"/>
                    <!-- SAVE -->
                    <Button x:Name="SaveBtn" Content="Save" Width="60"  Margin="5" Visibility="Collapsed" Click="SaveBtn_Click" Background="#33CC66"/>
                    <!-- CANCEL -->
                    <Button x:Name="CancelBtn" Content="Cancel" Width="80" Margin="5" Visibility="Collapsed" Click="CancelBtn_Click" Background="OrangeRed"/>
                    <!-- TIME RANGE -->
                    <ComboBox x:Name="TimeRangeCombo" Width="80" Margin="5" SelectedIndex="1" BorderThickness="0"  Background="Transparent">
                        <ComboBoxItem Content="Last 24h"/>
                        <ComboBoxItem Content="Last 7 days"/>
                        <ComboBoxItem Content="Last 30 days"/>
                        <ComboBoxItem Content="Custom"/>
                    </ComboBox>
                    <!-- THEME BUTTON -->
                    <Button x:Name="ThemeBtn" Content="🌙" Width="40" Margin="5" Click="ThemeBtn_Click"  BorderThickness="0" MinWidth="0" MinHeight="0"  Background="Transparent"/>
                    <!-- LANGUAGE -->
                    <ComboBox x:Name="LanguageCombo" Width="40" Margin="5" SelectionChanged="LanguageCombo_SelectionChanged" BorderThickness="0">
                        <ComboBoxItem Content="EN"/>
                        <ComboBoxItem Content="VI"/>
                    </ComboBox>
                    <!-- REFRESH -->
                    <Button x:Name="RefreshBtn" Content="🔄" Width="35" Margin="5" Click="RefreshBtn_Click" BorderThickness="0" Background="Transparent" Foreground="White" MinWidth="0" MinHeight="0"/>
                </StackPanel>
            </DockPanel>
        </Border>


        <!-- ================= SIDEBAR ================= -->

        <Border Grid.Row="1"
            Grid.Column="0"
            Background="#252526">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>


                <!-- MENU AREA -->

                <StackPanel Grid.Row="0">

                    <Expander Header="Dashboard"
                          FontSize="16"
                          x:Name="DashboardExpander"
                          Foreground="White"
                          Margin="5"
                          IsExpanded="True">

                        <StackPanel Margin="5">

                            <!-- OPERATIONS -->

                            <Button x:Name="OperationsBtn"
                                Tag="Operations"
                                Margin="5"
                                Click="Menu_Click"
                                Height="28"
                                Width="187"
                                Foreground="White"
                                BorderThickness="0"
                                Background="Transparent">

                                <StackPanel Orientation="Horizontal" Width="171">

                                    <TextBlock Text="📊"
                                           FontSize="16" Width="25"/>

                                    <TextBlock x:Name="OperationsText"
                                           Text=" Operations"
                                           Margin="10,-1,2,2"
                                           Foreground="White"/>

                                </StackPanel>

                            </Button>


                            <!-- ALARM MONITOR -->

                            <Button x:Name="AlarmMonitorBtn"
                                Tag="AlarmMonitor"
                                Margin="5"
                                Click="Menu_Click"
                                Height="28"
                                Width="187"
                                Foreground="White"
                                BorderThickness="0"
                                Background="Transparent">

                                <StackPanel Orientation="Horizontal" Width="171">

                                    <TextBlock Text="⚠"
                                           FontSize="16"/>

                                    <TextBlock x:Name="AlarmMonitorText"
                                           Text=" Alarm Monitor"
                                           Foreground="White"
                                           Margin="10,-1,2,2" Width="139"/>

                                </StackPanel>

                            </Button>

                        </StackPanel>

                    </Expander>

                </StackPanel>


                <!-- COLLAPSE BUTTON -->

                <Border Grid.Row="1"
                    BorderBrush="#444"
                    BorderThickness="0,1,0,0"
                    Background="#252526">

                    <Button Content="☰ Collapse"
                        HorizontalAlignment="Left"
                        Margin="10"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Click="ToggleSidebar_Click"/>

                </Border>

            </Grid>

        </Border>



        <!-- ================= DASHBOARD AREA ================= -->

        <Border Grid.Row="1"
            Grid.Column="1"
            Background="#1E1E1E"
            Margin="5"
            ClipToBounds="True">

            <Grid ClipToBounds="True">

                <Canvas x:Name="DashboardGrid"
                    Background="Transparent"
                    AllowDrop="True"
                    ClipToBounds="True"
                    Drop="DashboardGrid_Drop"
                    DragOver="DashboardGrid_DragOver"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

            </Grid>

        </Border>



        <!-- ================= WIDGET LIBRARY ================= -->

        <Border x:Name="WidgetLibrary"
            Grid.Row="1"
            Grid.Column="2"
            Background="#2D2D30"
            Visibility="Collapsed"
            BorderBrush="#444"
            BorderThickness="1">

            <StackPanel Margin="10">

                <TextBlock Text="Widget Library"
                       FontSize="16"
                       Foreground="White"
                       Margin="0 0 0 10"/>

                <Button Content="Camera Online Count"
                    Margin="5"
                    Padding="6"
                    Height="50"
                    Background="#3C3C3C"
                    Foreground="White"
                    PreviewMouseMove="WidgetLibrary_MouseMove"/>

            </StackPanel>

        </Border>

    </Grid>

</UserControl>
