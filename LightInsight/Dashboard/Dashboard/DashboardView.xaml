<UserControl x:Class="LightInsight.Dashboard.Dashboard.DashboardView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="#1E1E1E"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch">
    <UserControl.Resources>
        <Style x:Key="FilterButton" TargetType="ToggleButton">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6 2"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ================= MAIN LAYOUT ================= -->
        <Grid.ColumnDefinitions>
            <!-- Sidebar -->
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>

            <!-- Dashboard -->
            <ColumnDefinition Width="*"/>

            <!-- Widget Library -->
            <ColumnDefinition x:Name="WidgetLibraryColumn" Width="0"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->

        <Border Grid.Row="0"
        Grid.Column="0"
        Grid.ColumnSpan="3"
        Background="#2B2B2B"
        Padding="10,5">

            <DockPanel LastChildFill="False">

                <!-- LEFT AREA -->
                <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Left"
                    VerticalAlignment="Center">

                    <!-- LOGO -->
                    <Border Height="30"
                    Margin="5,0,20,0"
                    CornerRadius="6">

                        <Image Source="/LightInsight;component/Dashboard/Asset/logo.png"
                       Stretch="Uniform"/>
                    </Border>

                    <!-- BREADCRUMB -->
                    <TextBlock x:Name="BreadcrumbText"
                       Text="Dashboard > Operations"
                       FontSize="16"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center"
                       Foreground="White"/>
                </StackPanel>


                <!-- RIGHT AREA -->
                <StackPanel Orientation="Horizontal"
                    DockPanel.Dock="Right"
                    VerticalAlignment="Center">

                    <!-- WORKSPACE -->
                    <Button x:Name="WorkspaceBtn"
                            Height="30"
                            Margin="5"
                            Click="WorkspaceBtn_Click"
                            Background="#3498DB"
                            Foreground="White"
                            Padding="12,4"
                            BorderThickness="0">

                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">

                            <TextBlock Text="⚙"
                                       FontSize="14"
                                       Margin="0,0,6,0"
                                       VerticalAlignment="Center"/>

                            <TextBlock Text="Workspace"
                                       VerticalAlignment="Center"/>

                        </StackPanel>

                    </Button>
                    <!-- EDIT LAYOUT -->
                    <Button x:Name="EditLayoutBtn"
                    Height="30"
                    Margin="5"
                    Click="EditLayoutBtn_Click"
                    Background="#F39C12"
                    Foreground="White"
                    Padding="12,4"
                    BorderThickness="0">

                        <StackPanel Orientation="Horizontal"
                            VerticalAlignment="Center">

                            <TextBlock Text="✏"
                               FontSize="14"
                               Margin="0,0,6,0"
                               VerticalAlignment="Center"/>

                            <TextBlock Text="Edit Layout"
                               VerticalAlignment="Center"/>

                        </StackPanel>

                    </Button>


                    <!-- SAVE -->
                    <Button x:Name="SaveBtn"
                    Content="Save"
                    Height="30"
                    Margin="5"
                    Visibility="Collapsed"
                    Click="SaveBtn_Click"
                    Background="#33CC66"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,4"/>


                    <!-- CANCEL -->
                    <Button x:Name="CancelBtn"
                    Content="Cancel"
                    Height="30"
                    Margin="5"
                    Visibility="Collapsed"
                    Click="CancelBtn_Click"
                    Background="OrangeRed"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="10,4"/>


                    <!-- TIME RANGE -->
                    <ComboBox x:Name="TimeRangeCombo"
                      Width="95"
                      Height="30"
                      Margin="5"
                      SelectedIndex="1"
                      BorderThickness="0">

                        <ComboBoxItem Content="Last 24h"/>
                        <ComboBoxItem Content="Last 7 days"/>
                        <ComboBoxItem Content="Last 30 days"/>
                        <ComboBoxItem Content="Custom"/>

                    </ComboBox>


                    <!-- THEME -->
                    <Button x:Name="ThemeBtn"
                    Content="🌙"
                    Width="36"
                    Height="30"
                    Margin="5"
                    Click="ThemeBtn_Click"
                    Background="Transparent"
                    BorderThickness="0"
                    MinWidth="0" 
                    MinHeight="0"
                    Foreground="White"/>


                    <!-- LANGUAGE -->
                    <ComboBox x:Name="LanguageCombo"
                      Width="40"
                      Height="30"
                      Margin="5"
                      BorderThickness="0"
                      SelectionChanged="LanguageCombo_SelectionChanged">
                        <ComboBoxItem Content="EN"/>
                        <ComboBoxItem Content="VI"/>
                    </ComboBox>


                    <!-- REFRESH -->
                    <Button x:Name="RefreshBtn"
                    Content="🔄"
                    Width="36"
                    Height="30"
                    Margin="5"
                    Click="RefreshBtn_Click"
                    Background="Transparent"
                    Foreground="White"
                    BorderThickness="0"
                    MinWidth="0" 
                    MinHeight="0"/>

                </StackPanel>

            </DockPanel>

        </Border>


        <!-- ================= SIDEBAR ================= -->

        <Border Grid.Row="1"
        Grid.Column="0"
        Background="#252526">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <!-- MENU AREA -->

                <StackPanel Grid.Row="0">

                    <Expander Header="Dashboard"
                      FontSize="16"
                      x:Name="DashboardExpander"
                      Foreground="White"
                      Margin="5"
                      IsExpanded="True">

                        <!-- 🔥 DYNAMIC MENU -->
                        <ItemsControl ItemsSource="{Binding DashboardMenus}">

                            <ItemsControl.ItemTemplate>
                                <DataTemplate>

                                    <Button Click="Menu_Click"
                                    Margin="5"
                                    Height="28"
                                    Width="187"
                                    Foreground="White"
                                    BorderThickness="0"
                                    Background="Transparent"
                                    HorizontalContentAlignment="Left">

                                        <StackPanel Orientation="Horizontal" Width="171">

                                            <!-- ICON -->
                                            <iconPacks:PackIconMaterial 
                                        Kind="{Binding Icon}" 
                                        Width="20" Height="20"
                                        Margin="0,0,10,0"/>

                                            <!-- TEXT -->
                                            <TextBlock Text="{Binding Name}"
                                               Foreground="White"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"/>

                                        </StackPanel>

                                    </Button>

                                </DataTemplate>
                            </ItemsControl.ItemTemplate>

                        </ItemsControl>

                    </Expander>

                </StackPanel>

                <!-- COLLAPSE BUTTON -->

                <Border Grid.Row="1"
                BorderBrush="#444"
                BorderThickness="0,1,0,0"
                Background="#252526">

                    <Button Content="☰ Collapse"
                    HorizontalAlignment="Left"
                    Margin="10"
                    Background="Transparent"
                    Foreground="White"
                    BorderThickness="0"
                    Click="ToggleSidebar_Click"/>

                </Border>

            </Grid>

        </Border>



        <!-- ================= DASHBOARD AREA ================= -->

        <Border Grid.Row="1"
        Grid.Column="1"
        Background="#1E1E1E"
        Margin="5"
        ClipToBounds="True">

            <ScrollViewer x:Name="DashboardScroll"
              VerticalScrollBarVisibility="Auto"
              ScrollChanged="DashboardScroll_ScrollChanged">

                <Grid>

                    <!-- DASHBOARD GRID -->
                    <Grid x:Name="DashboardGrid"
                          Background="Transparent"
                          MinHeight="1000"
                          AllowDrop="True"
                          Drop="DashboardGrid_Drop"
                          DragOver="DashboardGrid_DragOver">

                        <!-- 12 COLUMN -->
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                    </Grid>

                    <!-- GRID OVERLAY -->
                    <Grid x:Name="GridOverlay"
                          Visibility="Collapsed"
                          IsHitTestVisible="False">

                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>

                    </Grid>

                </Grid>

            </ScrollViewer>

        </Border>



        <!-- ================= WIDGET LIBRARY ================= -->

        <Border x:Name="WidgetLibrary"
        Grid.Row="1"
        Grid.Column="2"
        Width="280"
        Background="#2D2D30"
        Visibility="Collapsed"
        BorderBrush="#444"
        BorderThickness="1">

            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <DockPanel Grid.Row="0" Margin="0 0 0 10">
                    <TextBlock Text="Widget Library"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="White"
                       DockPanel.Dock="Left"/>
                </DockPanel>

                <!-- Search -->
                <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Height="28"
                 Margin="0 0 0 10"
                 Padding="6"
                 Background="#3C3C3C"
                 Foreground="White"
                 BorderBrush="#555"
                 TextChanged="SearchBox_TextChanged"/>

                <!-- Filter -->
                <StackPanel x:Name="FilterPanel"
                            Grid.Row="2"
                            Orientation="Horizontal">

                    <ToggleButton Content="KPI" Tag="KPI" Click="Filter_Click" Style="{StaticResource FilterButton}"/>
                    <ToggleButton Content="Charts" Tag="Charts" Click="Filter_Click" Style="{StaticResource FilterButton}"/>
                    <ToggleButton Content="Tables" Tag="Tables" Click="Filter_Click" Style="{StaticResource FilterButton}"/>
                    <ToggleButton Content="Lists" Tag="Lists" Click="Filter_Click" Style="{StaticResource FilterButton}"/>

                </StackPanel>

                <!-- Widget list -->
                <ScrollViewer Grid.Row="3">

                    <ListBox x:Name="WidgetList"
                             Grid.Row="3"
                             Background="Transparent"
                             BorderThickness="0"
                             Width="250"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border Background="#3C3C3C"
                                        Margin="0 4"
                                        Padding="8"
                                        CornerRadius="4"
                                        MouseMove="WidgetLibrary_MouseMove">

                                    <DockPanel LastChildFill="False">
                                        <Button Content="Add"
                                                MinHeight="0"
                                                MinWidth="0"
                                                Width="45"
                                                Height="22"
                                                DockPanel.Dock="Right"
                                                Margin="8 0 0 0"
                                                Tag="{Binding}"
                                                Click="AddWidget_Click"
                                                Background="#FF7A1A"
                                                Foreground="White"
                                                
                                                />
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>

                                    </DockPanel>

                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </ScrollViewer>

            </Grid>

        </Border>

    </Grid>

</UserControl>
