<UserControl x:Class="LightInsight.Dashboard.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             xmlns:local="clr-namespace:LightInsight.Dashboard.Dashboard"
             xmlns:ws="clr-namespace:LightInsight.Dashboard.Dashboard.Workspace"
             Background="{DynamicResource BgMain}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             x:Name="RootControl">
    
    <UserControl.Resources>
        <Style x:Key="NoArrowExpander" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}">
                            <StackPanel>
                                <ToggleButton x:Name="HeaderSite" IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}" Background="Transparent" BorderThickness="0" Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}" Padding="2">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <ContentPresenter Content="{TemplateBinding Header}" ContentTemplate="{TemplateBinding HeaderTemplate}"/>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite" Visibility="Collapsed" Content="{TemplateBinding Content}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <HierarchicalDataTemplate x:Key="SidebarItemTemplate" ItemsSource="{Binding Children}">
            <Grid>
                <!-- ===== MAIN ITEM ===== -->
                <StackPanel>
                    <Border x:Name="ItemBorder"
                    Height="40"
                    Cursor="Hand"
                    Background="Transparent"
                    MouseLeftButtonDown="Menu_Click"
                    Tag="{Binding ElementName=SubMenuPopup}"
                    MouseEnter="ItemBorder_MouseEnter"
                    MouseLeave="ItemBorder_MouseLeave">     

                        <Grid x:Name="ItemGrid">
                            <Border x:Name="SelectedAccent"
                            Width="3"
                            HorizontalAlignment="Left"
                            Background="{DynamicResource AccentColor}"
                            Visibility="Collapsed"/>

                            <Grid x:Name="ContentGrid" Margin="12,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <!-- ICON -->
                                <iconPacks:PackIconMaterial
                            Kind="{Binding Icon}"
                            Width="16"
                            Height="16"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            Foreground="{DynamicResource TextSecondary}"/>

                                <!-- TEXT -->
                                <TextBlock Grid.Column="1"
                                   x:Name="ItemText"
                                   Text="{Binding DisplayTitle}"
                                   VerticalAlignment="Center"
                                   Margin="12,0"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="13"
                                   TextTrimming="CharacterEllipsis"/>

                                <!-- ARROW -->
                                <iconPacks:PackIconMaterial Grid.Column="2"
                                                    x:Name="ArrowIcon"
                                                    Kind="ChevronRight"
                                                    Width="10"
                                                    Height="10"
                                                    VerticalAlignment="Center"
                                                    HorizontalAlignment="Center"
                                                    Foreground="{DynamicResource TextMuted}"
                                                    Visibility="Collapsed"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- CHILD INLINE -->
                    <ItemsControl x:Name="ChildrenPresenter"
                          ItemsSource="{Binding Children}"
                          Margin="25,0,0,0"
                          Visibility="Collapsed"
                          ItemTemplate="{DynamicResource SidebarItemTemplate}"/>
                </StackPanel>

                <!-- ===== POPUP ===== -->
                <Popup x:Name="SubMenuPopup"
               Placement="Right"
               PlacementTarget="{Binding ElementName=ItemBorder}"
               StaysOpen="True"
               AllowsTransparency="True"
               PopupAnimation="Fade">

                    <Border Background="#2B2F38"
                    BorderBrush="#444"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="8"
                    MouseEnter="Popup_MouseEnter"
                    MouseLeave="Popup_MouseLeave">

                        <ItemsControl ItemsSource="{Binding Children}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Padding="8"
                                    Background="Transparent"
                                    Cursor="Hand"
                                    MouseLeftButtonDown="Menu_Click">

                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter Property="Background" Value="#3A3F4B"/>
                                                    </Trigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>

                                        <TextBlock Text="{Binding DisplayTitle}"
                                           Foreground="White"/>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </Border>
                </Popup>
            </Grid>

            <!-- ===== TRIGGERS ===== -->
            <HierarchicalDataTemplate.Triggers>

                <!-- GROUP -->
                <DataTrigger Binding="{Binding IsGroup}" Value="True">
                    <Setter TargetName="ArrowIcon" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <!-- EXPAND -->
                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter TargetName="ArrowIcon" Property="Kind" Value="ChevronDown"/>
                    <Setter TargetName="ChildrenPresenter" Property="Visibility" Value="Visible"/>
                </DataTrigger>

                <!-- SELECT -->
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="SelectedAccent" Property="Visibility" Value="Visible"/>
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource SidebarHeaderBackgroundBrush}"/>
                </DataTrigger>

                <!-- COLLAPSE -->
                <DataTrigger Binding="{Binding IsSidebarCollapsed, ElementName=RootControl}" Value="True">
                    <Setter TargetName="ItemText" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ArrowIcon" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ChildrenPresenter" Property="Visibility" Value="Collapsed"/>
                    <Setter TargetName="ContentGrid" Property="Margin" Value="0"/>
                    <Setter TargetName="ContentGrid" Property="HorizontalAlignment" Value="Center"/>
                </DataTrigger>

                <!-- HOVER BG -->
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="ItemBorder" Property="Background" Value="{DynamicResource ItemHoverBg}"/>
                </Trigger>

            </HierarchicalDataTemplate.Triggers>
        </HierarchicalDataTemplate>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgMain}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="WidgetLibraryColumn" Width="0"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" Background="{DynamicResource BgMain}" Padding="10,5" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,0,1">
            <Grid>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                    <Border Height="30" Margin="5,0,20,0" CornerRadius="6">
                        <Image Source="../Asset/logo.png" Stretch="Uniform"/>
                    </Border>
                    <TextBlock x:Name="BreadcrumbText" Text="{DynamicResource Breadcrumb_Default}" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="WorkspaceBtn" Height="32" Margin="5" Click="WorkspaceBtn_Click" Background="#3498DB" Foreground="White" Padding="12,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Workspace}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="EditLayoutBtn" Height="32" Margin="5" Click="EditLayoutBtn_Click" Background="{DynamicResource AccentColor}" Foreground="White" Padding="12,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EditLayout}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SaveBtn" Height="32" Margin="5" Visibility="Collapsed" Click="SaveBtn_Click" Background="{DynamicResource StatusOnline}" Foreground="White" Padding="12,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Save}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="CancelBtn" Height="32" Margin="5" Visibility="Collapsed" Click="CancelBtn_Click" Background="{DynamicResource StatusOffline}" Foreground="White" Padding="12,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cancel}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ComboBox x:Name="TimeRangeCombo" Width="110" Height="32" Margin="5" SelectedIndex="0" Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource CardBorder}">
                        <ComboBox.Resources><Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style></ComboBox.Resources>
                        <ComboBoxItem Content="{DynamicResource Last24h}"/><ComboBoxItem Content="{DynamicResource Last7Days}"/><ComboBoxItem Content="{DynamicResource Last30Days}"/><ComboBoxItem Content="{DynamicResource Custom}"/>
                    </ComboBox>

                    <Button x:Name="RefreshBtn" Width="32" Height="32" Margin="5" Click="RefreshBtn_Click" Background="Transparent" BorderThickness="0" Cursor="Hand" MinHeight="0" MinWidth="20">
                        <iconPacks:PackIconMaterial Kind="Refresh" Foreground="{DynamicResource TextSecondary}" Width="14" Height="14"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ================= SIDEBAR ================= -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource ButtonBg}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding NavigationItems}" 
                                  ItemTemplate="{DynamicResource SidebarItemTemplate}"
                                  Margin="0,5">
                    </ItemsControl>
                </ScrollViewer>

                <Border Grid.Row="1" BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,1,0,0" Background="Transparent" Cursor="Hand" PreviewMouseLeftButtonDown="ToggleSidebar_Click">
                    <Grid Margin="12,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" x:Name="ToggleStack">
                            <iconPacks:PackIconMaterial x:Name="CollapseIcon" Kind="ChevronLeft" Width="16" Height="16" Foreground="{DynamicResource TextPrimary}"/>
                            <TextBlock x:Name="ToggleText" Text="{DynamicResource Collapse}" Margin="12,0,0,0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed, ElementName=RootControl}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- ================= DASHBOARD AREA ================= -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource BgMain}" Margin="5">
            <ScrollViewer x:Name="DashboardScroll" VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Grid x:Name="GridOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                    <Grid x:Name="DashboardGrid" Background="Transparent" MinHeight="1000" AllowDrop="False" Drop="DashboardGrid_Drop" PreviewDragOver="DashboardGrid_DragOver">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- ================= WIDGET LIBRARY ================= -->
        <Border x:Name="WidgetLibrary" Grid.Row="1" Grid.Column="2" Width="320" Background="{DynamicResource BgMain}" Visibility="Collapsed" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1,0,0,0">
            <Grid Margin="20,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Widget Library" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Click a widget to add it to the dashboard" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Click="ExitEditModeBtn_Click" Cursor="Hand">
                        <iconPacks:PackIconMaterial Kind="Close" Foreground="{DynamicResource TextSecondary}" Width="18" Height="18"/>
                    </Button>
                </Grid>

                <Border Grid.Row="1" Background="{DynamicResource ButtonBg}" CornerRadius="4" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Margin="0,0,0,15">
                    <Grid Height="32">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <iconPacks:PackIconMaterial Kind="Magnify" Foreground="{DynamicResource TextSecondary}" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Foreground="{DynamicResource TextPrimary}" CaretBrush="White" TextChanged="SearchBox_TextChanged"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding WidgetGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,20">
                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10" Background="Transparent" Cursor="Hand" x:Name="ItemContainer"
                                                        PreviewMouseLeftButtonDown="WidgetLibrary_PreviewMouseLeftButtonDown" 
                                                        PreviewMouseMove="WidgetLibrary_MouseMove"
                                                        PreviewMouseLeftButtonUp="WidgetLibrary_Item_PreviewMouseLeftButtonUp">
                                                    <Grid x:Name="ItemGrid">
                                                        <Grid.ColumnDefinitions><ColumnDefinition Width="36"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                                                        <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource SidebarHeaderBackgroundBrush}" VerticalAlignment="Center">
                                                            <iconPacks:PackIconMaterial Kind="{Binding Icon}" Foreground="{DynamicResource AccentColor}" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0,0,0" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" SourceName="ItemContainer" Value="True"><Setter TargetName="ItemGrid" Property="Opacity" Value="0.7"/></Trigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>