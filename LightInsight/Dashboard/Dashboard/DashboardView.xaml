<UserControl x:Class="LightInsight.Dashboard.Dashboard.DashboardView"
 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
 Background="#1E1E1E">
    <UserControl.Resources>

        <Style TargetType="ToggleButton">

            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="10"/>

            <Style.Triggers>

                <Trigger Property="IsChecked" Value="True">
                    <Setter Property="Background" Value="#007ACC"/>
                </Trigger>

            </Style.Triggers>

        </Style>

    </UserControl.Resources>
    <Grid>

        <!-- Layout tổng -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <!-- Sidebar -->
            <ColumnDefinition Width="*"/>
            <!-- Dashboard -->
            <ColumnDefinition Width="300"/>
            <!-- Widget Library -->
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->

        <Border Grid.Column="1"
                Grid.ColumnSpan="2"
                Background="#2B2B2B"
                Padding="10">

            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <!-- Edit Layout -->
                <Button x:Name="EditLayoutBtn"
                        Content="Edit Layout"
                        Width="110"
                        Margin="5"
                        Click="EditLayoutBtn_Click"/>

                <!-- Save -->
                <Button x:Name="SaveBtn"
                        Content="Save"
                        Width="80"
                        Margin="5"
                        Visibility="Collapsed"
                        Click="SaveBtn_Click"/>

                <!-- Cancel -->
                <Button x:Name="CancelBtn"
                        Content="Cancel"
                        Width="80"
                        Margin="5"
                        Visibility="Collapsed"
                        Click="CancelBtn_Click"/>
            </StackPanel>

        </Border>


        <!-- ================= SIDEBAR ================= -->

        <Border Grid.RowSpan="2"
                Grid.Column="0"
                Background="#252526">

            <StackPanel>

                <TextBlock Text="Light VMS"
                           Foreground="Orange"
                           FontSize="18"
                           Margin="15"/>

                <!-- Dashboard menu -->

                <Expander Header="Dashboard"
                          Foreground="White"
                          Margin="5"
                          IsExpanded="True">

                    <StackPanel Margin="10 0">

                        <Button x:Name="OperationsBtn"
                                Content="Operations"
                                Margin="5"
                                Click="Menu_Click"/>

                        <Button x:Name="AlarmMonitorBtn"
                                Content="Alarm Monitor"
                                Margin="5"
                                Click="Menu_Click"/>

                    </StackPanel>

                </Expander>


                <!-- Menu khác -->


            </StackPanel>

        </Border>


        <!-- ================= DASHBOARD AREA ================= -->

        <Border Grid.Row="1"
                Grid.Column="1"
                Background="#1E1E1E"
                Margin="5">

            <Canvas x:Name="DashboardGrid"
                    AllowDrop="True"
                    Drop="DashboardGrid_Drop"
                    DragOver="DashboardGrid_DragOver"
                    Background="Transparent">

                <TextBlock Text="Dashboard Area"
                           Foreground="Gray"
                           FontSize="22"
                           IsHitTestVisible="False"
                           Canvas.Left="300"
                           Canvas.Top="200"/>   

            </Canvas>

        </Border>


        <!-- ================= WIDGET LIBRARY ================= -->

        <Border x:Name="WidgetLibrary"
                Grid.Row="1"
                Grid.Column="2"
                Background="#2D2D30"
                Visibility="Collapsed"
                BorderBrush="#444"
                BorderThickness="1">

            <StackPanel Margin="10">

                <TextBlock Text="Widget Library"
                           FontSize="16"
                           Foreground="White"
                           Margin="0 0 0 10"/>

                <!-- Placeholder widgets -->

                <Button Content="Camera Online Count"
                        Margin="5"
                        Padding="6"
                        Height="50"
                        Background="#3C3C3C"
                        Foreground="White"
                        PreviewMouseLeftButtonDown="Widget_MouseDown"
                        PreviewMouseMove="Widget_MouseMove"/>

            </StackPanel>

        </Border>

    </Grid>
</UserControl>