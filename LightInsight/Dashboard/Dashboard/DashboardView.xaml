<UserControl x:Class="LightInsight.Dashboard.Dashboard.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
             xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
             Background="{DynamicResource BgMain}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch">
    
    <UserControl.Resources>
        <Style x:Key="FilterButton" TargetType="ToggleButton">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6,2"/>
            <Setter Property="Background" Value="{DynamicResource CardBg}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
        </Style>

        <Style x:Key="NoArrowExpander" TargetType="Expander">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <Border Background="{TemplateBinding Background}">
                            <StackPanel>
                                <ToggleButton x:Name="HeaderSite"
                                              IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              Cursor="Hand">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="ToggleButton">
                                            <Border Background="{TemplateBinding Background}" Padding="2">
                                                <ContentPresenter />
                                            </Border>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                    <ContentPresenter Content="{TemplateBinding Header}"
                                                      ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                      RecognizesAccessKey="True"/>
                                </ToggleButton>
                                <ContentPresenter x:Name="ExpandSite"
                                                  Visibility="Collapsed"
                                                  Margin="0,5,0,0"
                                                  Content="{TemplateBinding Content}"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource BgMain}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition x:Name="WidgetLibraryColumn" Width="0"/>
        </Grid.ColumnDefinitions>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="3" 
                Background="{DynamicResource BgMain}" 
                Padding="10,5"
                BorderBrush="{DynamicResource CardBorder}"
                BorderThickness="0,0,0,1">
            <DockPanel LastChildFill="False">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <Border Height="30" Margin="5,0,20,0" CornerRadius="6">
                        <Image Source="/LightInsight;component/Dashboard/Asset/logo.png" Stretch="Uniform"/>
                    </Border>
                    <TextBlock x:Name="BreadcrumbText" Text="{DynamicResource Breadcrumb_Default}"
                               FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Button x:Name="WorkspaceBtn" Height="32" Margin="5" Click="WorkspaceBtn_Click" 
                            Background="#3498DB" Foreground="White" Padding="12,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Cog" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Workspace}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="EditLayoutBtn" Height="32" Margin="5" Click="EditLayoutBtn_Click" 
                            Background="{DynamicResource AccentColor}" Foreground="White" Padding="12,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Pencil" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource EditLayout}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="SaveBtn" Height="32" Margin="5" Visibility="Collapsed" Click="SaveBtn_Click" 
                            Background="{DynamicResource StatusOnline}" Foreground="White" Padding="12,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="ContentSave" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Save}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button x:Name="CancelBtn" Height="32" Margin="5" Visibility="Collapsed" Click="CancelBtn_Click" 
                            Background="{DynamicResource StatusOffline}" Foreground="White" Padding="12,0" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </Button.Resources>
                        <StackPanel Orientation="Horizontal">
                            <iconPacks:PackIconMaterial Kind="Close" Width="14" Height="14" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="{DynamicResource Cancel}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <ComboBox x:Name="TimeRangeCombo" Width="110" Height="32" Margin="5" SelectedIndex="0" 
                              Background="{DynamicResource ButtonBg}" Foreground="{DynamicResource TextPrimary}" BorderBrush="{DynamicResource CardBorder}">
                        <ComboBox.Resources>
                            <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                        </ComboBox.Resources>
                        <ComboBoxItem Content="Last 24h"/>
                        <ComboBoxItem Content="Last 7 Days"/>
                        <ComboBoxItem Content="Last 30 Days"/>
                        <ComboBoxItem Content="Custom"/>
                    </ComboBox>

                    <Button x:Name="RefreshBtn" Width="32" Height="32" Margin="5" Click="RefreshBtn_Click" Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <iconPacks:PackIconMaterial Kind="Refresh" Foreground="{DynamicResource TextSecondary}" Width="18" Height="18"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- ================= SIDEBAR ================= -->
        <Border Grid.Row="1" Grid.Column="0" Background="{DynamicResource ButtonBg}" 
                BorderBrush="{DynamicResource CardBorder}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>

                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <Expander x:Name="DashboardExpander" Style="{StaticResource NoArrowExpander}" Margin="0,5" IsExpanded="True" 
                                  Background="Transparent" BorderThickness="0" MouseEnter="Expander_MouseEnter" MouseLeave="Expander_MouseLeave">
                            <Expander.Header>
                                <Grid Height="40" Margin="10,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="ViewDashboard" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}"/>
                                    <TextBlock Grid.Column="1" Text="{DynamicResource Dashboard}" VerticalAlignment="Center" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                    <iconPacks:PackIconMaterial Grid.Column="2" Kind="ChevronDown" Width="16" Height="16" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}">
                                        <iconPacks:PackIconMaterial.Style>
                                            <Style TargetType="iconPacks:PackIconMaterial">
                                                <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                                        <Setter Property="Visibility" Value="Collapsed"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="False">
                                                        <Setter Property="RenderTransform"><Setter.Value><RotateTransform Angle="-90"/></Setter.Value></Setter>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsExpanded, RelativeSource={RelativeSource AncestorType=Expander}}" Value="True">
                                                        <Setter Property="RenderTransform"><Setter.Value><RotateTransform Angle="0"/></Setter.Value></Setter>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </iconPacks:PackIconMaterial.Style>
                                    </iconPacks:PackIconMaterial>
                                </Grid>
                            </Expander.Header>

                            <ItemsControl ItemsSource="{Binding DashboardMenus}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True"><Setter Property="Visibility" Value="Collapsed"/></DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid x:Name="ItemGrid" Height="36">
                                            <!-- ACCENT BORDER -->
                                            <Border x:Name="SelectedAccent" Width="3" HorizontalAlignment="Left" Background="{DynamicResource AccentColor}" Visibility="Collapsed"/>

                                            <Button Click="Menu_Click" Padding="15,0,0,0" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" Background="Transparent" HorizontalContentAlignment="Left">
                                                <Button.Style>
                                                    <Style TargetType="Button">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource ItemHoverBg}"/></Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Button.Style>
                                                <StackPanel Orientation="Horizontal">
                                                    <iconPacks:PackIconMaterial Kind="{Binding Icon}" Width="16" Height="16" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter TargetName="SelectedAccent" Property="Visibility" Value="Visible"/>
                                                <Setter TargetName="ItemGrid" Property="Background" Value="{DynamicResource SidebarHeaderBackgroundBrush}"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>

                        <Popup x:Name="SubMenuPopup" Placement="Right" PlacementTarget="{Binding ElementName=DashboardExpander}" AllowsTransparency="True" PopupAnimation="Fade" HorizontalOffset="0">
                            <Border Background="Transparent" Padding="5,0,20,20">
                                <Border Background="{DynamicResource CardBg}" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" CornerRadius="4" Padding="5">
                                    <Border.Effect><DropShadowEffect BlurRadius="15" Opacity="0.4" ShadowDepth="3"/></Border.Effect>
                                    <ItemsControl ItemsSource="{Binding DashboardMenus}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Click="Menu_Click" Margin="2" Height="32" Width="180" Foreground="{DynamicResource TextPrimary}" BorderThickness="0" HorizontalContentAlignment="Left">
                                                    <Button.Style>
                                                        <Style TargetType="Button">
                                                            <Setter Property="Background" Value="Transparent"/>
                                                            <Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="{DynamicResource ItemHoverBg}"/></Trigger></Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <StackPanel Orientation="Horizontal">
                                                        <iconPacks:PackIconMaterial Kind="{Binding Icon}" Width="16" Height="16" Margin="5,0,10,0" VerticalAlignment="Center" Foreground="{DynamicResource TextSecondary}"/>
                                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontSize="13"/>
                                                    </StackPanel>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Border>
                            </Border>
                        </Popup>
                    </StackPanel>
                </ScrollViewer>

                <Border Grid.Row="1" BorderBrush="#444" BorderThickness="0,1,0,0" Background="{DynamicResource BgMain}" Cursor="Hand" PreviewMouseLeftButtonDown="ToggleSidebar_Click">
                    <Border.Style>
                        <Style TargetType="Border"><Style.Triggers><Trigger Property="IsMouseOver" Value="True"><Setter Property="Background" Value="#333"/></Trigger></Style.Triggers></Style>
                    </Border.Style>
                    <Button HorizontalAlignment="Left" Margin="10" Background="Transparent" Foreground="White" BorderThickness="0" IsHitTestVisible="False">
                        <Button.Style>
                            <Style TargetType="Button">
                                <Setter Property="Content" Value="{DynamicResource Collapse}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSidebarCollapsed, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="True">
                                        <Setter Property="Content" Value="☰"/><Setter Property="HorizontalAlignment" Value="Center"/><Setter Property="Margin" Value="0"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                    </Button>
                </Border>
            </Grid>
        </Border>

        <!-- ================= DASHBOARD AREA ================= -->
        <Border Grid.Row="1" Grid.Column="1" Background="{DynamicResource BgMain}" Margin="5" ClipToBounds="True">
            <ScrollViewer x:Name="DashboardScroll" VerticalScrollBarVisibility="Auto" PanningMode="VerticalOnly" PreviewMouseWheel="DashboardScroll_PreviewMouseWheel" ScrollChanged="DashboardScroll_ScrollChanged">
                <Grid>
                    <Grid x:Name="DashboardGrid" Background="Transparent" MinHeight="1000" AllowDrop="True" IsHitTestVisible="True" Drop="DashboardGrid_Drop" DragOver="DashboardGrid_DragOver">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                    <Grid x:Name="GridOverlay" Visibility="Collapsed" IsHitTestVisible="False">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/><ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>

        <!-- ================= WIDGET LIBRARY ================= -->
        <Border x:Name="WidgetLibrary" Grid.Row="1" Grid.Column="2" Width="320" Background="{DynamicResource BgMain}" Visibility="Collapsed" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1,0,0,0">
            <Grid Margin="20,15">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Widget Library" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextPrimary}"/>
                        <TextBlock Text="Click a widget to add it to the dashboard" FontSize="11" Foreground="{DynamicResource TextSecondary}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <Button Grid.Column="1" Background="Transparent" BorderThickness="0" Click="ExitEditModeBtn_Click" Cursor="Hand">
                        <iconPacks:PackIconMaterial Kind="Clipboard" Foreground="{DynamicResource TextSecondary}" Width="18" Height="18"/>
                    </Button>
                </Grid>

                <!-- SEARCH -->
                <Border Grid.Row="1" Background="{DynamicResource ButtonBg}" CornerRadius="4" BorderBrush="{DynamicResource CardBorder}" BorderThickness="1" Margin="0,0,0,15">
                    <Grid Height="32">
                        <Grid.ColumnDefinitions><ColumnDefinition Width="32"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                        <iconPacks:PackIconMaterial Kind="Magnify" Foreground="{DynamicResource TextSecondary}" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <TextBox Grid.Column="1" x:Name="SearchBox" Background="Transparent" BorderThickness="0" VerticalContentAlignment="Center" Foreground="{DynamicResource TextPrimary}" CaretBrush="White" TextChanged="SearchBox_TextChanged"/>
                    </Grid>
                </Border>

                <!-- GROUPED LIST -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding WidgetGroups}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="0,0,0,20">
                                    <!-- GROUP TITLE -->
                                    <TextBlock Text="{Binding Title}" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="13" Margin="0,0,0,10"/>
                                    
                                    <!-- ITEMS IN GROUP -->
                                    <ItemsControl ItemsSource="{Binding Items}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Margin="0,0,0,10" 
                                                        Background="Transparent" 
                                                        Cursor="Hand" 
                                                        x:Name="ItemContainer"
                                                        PreviewMouseLeftButtonDown="WidgetLibrary_PreviewMouseLeftButtonDown" 
                                                        PreviewMouseMove="WidgetLibrary_MouseMove"
                                                        PreviewMouseLeftButtonUp="WidgetLibrary_Item_PreviewMouseLeftButtonUp">
                                                    <Grid x:Name="ItemGrid">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="36"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>
                                                        
                                                        <!-- ICON -->
                                                        <Border Width="28" Height="28" CornerRadius="14" Background="{DynamicResource SidebarHeaderBackgroundBrush}" VerticalAlignment="Center">
                                                            <iconPacks:PackIconMaterial Kind="{Binding Icon}" Foreground="{DynamicResource AccentColor}" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>

                                                        <!-- TEXT -->
                                                        <TextBlock Grid.Column="1" Text="{Binding Name}" Margin="10,0,0,0" Foreground="{DynamicResource TextPrimary}" FontWeight="SemiBold" FontSize="12" VerticalAlignment="Center" TextWrapping="Wrap"/>
                                                    </Grid>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <Trigger Property="IsMouseOver" SourceName="ItemContainer" Value="True">
                                                        <Setter TargetName="ItemGrid" Property="Opacity" Value="0.7"/>
                                                    </Trigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>
