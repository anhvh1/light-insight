<UserControl x:Class="LightInsight.Dashboard.Dashboard.DashboardView"
xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
Background="#1E1E1E">
    <UserControl.Resources>
        <Style x:Key="FilterButton" TargetType="ToggleButton">
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Padding" Value="6 2"/>
            <Setter Property="Background" Value="#3C3C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderBrush" Value="#555"/>
        </Style>
    </UserControl.Resources>

    <Grid>
        <!-- ================= MAIN LAYOUT ================= -->
        <Grid.ColumnDefinitions>
            <ColumnDefinition x:Name="SidebarColumn" Width="220"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid.RowDefinitions>
            <RowDefinition Height="50"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ================= TOP BAR ================= -->

        <Border Grid.Column="0"
            Grid.ColumnSpan="3"
            Background="#2B2B2B"
            Padding="10">

            <DockPanel LastChildFill="False">
                <!-- LEFT AREA -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <!-- LOGO -->
                    <Border Height="30" Margin="5,0,20,0" CornerRadius="8" Background="Transparent">
                        <Image Source="/LightInsight;component/Dashboard/Asset/logo.png" Stretch="Uniform"/>
                    </Border>
                    <!-- BREADCRUMB -->
                    <TextBlock x:Name="BreadcrumbText" Text="Dashboard" FontSize="16" FontWeight="SemiBold" VerticalAlignment="Center" Foreground="White"/>
                </StackPanel>
                <!-- RIGHT AREA -->
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                    <!-- EDIT LAYOUT -->
                    <Button x:Name="EditLayoutBtn" Content="Edit Layout" Width="90" Margin="5" Click="EditLayoutBtn_Click" Background="Orange"/>
                    <!-- SAVE -->
                    <Button x:Name="SaveBtn" Content="Save" Width="60"  Margin="5" Visibility="Collapsed" Click="SaveBtn_Click" Background="#33CC66"/>
                    <!-- CANCEL -->
                    <Button x:Name="CancelBtn" Content="Cancel" Width="80" Margin="5" Visibility="Collapsed" Click="CancelBtn_Click" Background="OrangeRed"/>
                    <!-- TIME RANGE -->
                    <ComboBox x:Name="TimeRangeCombo" Width="80" Margin="5" SelectedIndex="1" BorderThickness="0"  Background="Transparent">
                        <ComboBoxItem Content="Last 24h"/>
                        <ComboBoxItem Content="Last 7 days"/>
                        <ComboBoxItem Content="Last 30 days"/>
                        <ComboBoxItem Content="Custom"/>
                    </ComboBox>
                    <!-- THEME BUTTON -->
                    <Button x:Name="ThemeBtn" Content="🌙" Width="40" Margin="5" Click="ThemeBtn_Click"  BorderThickness="0" MinWidth="0" MinHeight="0"  Background="Transparent"/>
                    <!-- LANGUAGE -->
                    <ComboBox x:Name="LanguageCombo" Width="40" Margin="5" SelectionChanged="LanguageCombo_SelectionChanged" BorderThickness="0">
                        <ComboBoxItem Content="EN"/>
                        <ComboBoxItem Content="VI"/>
                    </ComboBox>
                    <!-- REFRESH -->
                    <Button x:Name="RefreshBtn" Content="🔄" Width="35" Margin="5" Click="RefreshBtn_Click" BorderThickness="0" Background="Transparent" Foreground="White" MinWidth="0" MinHeight="0"/>
                </StackPanel>
            </DockPanel>
        </Border>


        <!-- ================= SIDEBAR ================= -->

        <Border Grid.Row="1"
            Grid.Column="0"
            Background="#252526">

            <Grid>

                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="50"/>
                </Grid.RowDefinitions>


                <!-- MENU AREA -->

                <StackPanel Grid.Row="0">

                    <Expander Header="Dashboard"
                          FontSize="16"
                          x:Name="DashboardExpander"
                          Foreground="White"
                          Margin="5"
                          IsExpanded="True">

                        <StackPanel Margin="5">

                            <!-- OPERATIONS -->

                            <Button x:Name="OperationsBtn"
                                Tag="Operations"
                                Margin="5"
                                Click="Menu_Click"
                                Height="28"
                                Width="187"
                                Foreground="White"
                                BorderThickness="0"
                                Background="Transparent">

                                <StackPanel Orientation="Horizontal" Width="171">

                                    <TextBlock Text="📊"
                                           FontSize="16" Width="25"/>

                                    <TextBlock x:Name="OperationsText"
                                           Text=" Operations"
                                           Margin="10,-1,2,2"
                                           Foreground="White"/>

                                </StackPanel>

                            </Button>


                            <!-- ALARM MONITOR -->

                            <Button x:Name="AlarmMonitorBtn"
                                Tag="AlarmMonitor"
                                Margin="5"
                                Click="Menu_Click"
                                Height="28"
                                Width="187"
                                Foreground="White"
                                BorderThickness="0"
                                Background="Transparent">

                                <StackPanel Orientation="Horizontal" Width="171">

                                    <TextBlock Text="⚠"
                                           FontSize="16"/>

                                    <TextBlock x:Name="AlarmMonitorText"
                                           Text=" Alarm Monitor"
                                           Foreground="White"
                                           Margin="10,-1,2,2" Width="139"/>

                                </StackPanel>

                            </Button>

                        </StackPanel>

                    </Expander>

                </StackPanel>


                <!-- COLLAPSE BUTTON -->

                <Border Grid.Row="1"
                    BorderBrush="#444"
                    BorderThickness="0,1,0,0"
                    Background="#252526">

                    <Button Content="☰ Collapse"
                        HorizontalAlignment="Left"
                        Margin="10"
                        Background="Transparent"
                        Foreground="White"
                        BorderThickness="0"
                        Click="ToggleSidebar_Click"/>

                </Border>

            </Grid>

        </Border>



        <!-- ================= DASHBOARD AREA ================= -->

        <Border Grid.Row="1"
            Grid.Column="1"
            Background="#1E1E1E"
            Margin="5"
            ClipToBounds="True">

            <Grid ClipToBounds="True">

                <Canvas x:Name="DashboardGrid"
                    Background="Transparent"
                    AllowDrop="True"
                    ClipToBounds="True"
                    Drop="DashboardGrid_Drop"
                    DragOver="DashboardGrid_DragOver"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"/>

            </Grid>

        </Border>



        <!-- ================= WIDGET LIBRARY ================= -->

        <Border x:Name="WidgetLibrary"
        Grid.Row="1"
        Grid.Column="2"
        Width="280"
        Background="#2D2D30"
        Visibility="Collapsed"
        BorderBrush="#444"
        BorderThickness="1">

            <Grid Margin="10">

                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <DockPanel Grid.Row="0" Margin="0 0 0 10">
                    <TextBlock Text="Widget Library"
                       FontSize="16"
                       FontWeight="SemiBold"
                       Foreground="White"
                       DockPanel.Dock="Left"/>
                </DockPanel>

                <!-- Search -->
                <TextBox x:Name="SearchBox"
                 Grid.Row="1"
                 Height="28"
                 Margin="0 0 0 10"
                 Padding="6"
                 Background="#3C3C3C"
                 Foreground="White"
                 BorderBrush="#555"
                 TextChanged="SearchBox_TextChanged"/>

                <!-- Filter -->
                <StackPanel x:Name="FilterPanel"
                            Grid.Row="2"
                            Orientation="Horizontal">

                    <ToggleButton Content="KPI" Tag="KPI" Click="Filter_Click" Style="{StaticResource FilterButton}"/>
                    <ToggleButton Content="Charts" Tag="Charts" Click="Filter_Click" Style="{StaticResource FilterButton}"/>
                    <ToggleButton Content="Tables" Tag="Tables" Click="Filter_Click" Style="{StaticResource FilterButton}"/>
                    <ToggleButton Content="Lists" Tag="Lists" Click="Filter_Click" Style="{StaticResource FilterButton}"/>

                </StackPanel>

                <!-- Widget list -->
                <ScrollViewer Grid.Row="3">

                    <ListBox x:Name="WidgetList"
                             Grid.Row="3"
                             Background="Transparent"
                             BorderThickness="0"
                             Width="250"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">

                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>

                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="Transparent"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListBox.ItemContainerStyle>

                        <ListBox.ItemTemplate>
                            <DataTemplate>

                                <Border Background="#3C3C3C"
                                        Margin="0 4"
                                        Padding="8"
                                        CornerRadius="4">

                                    <DockPanel LastChildFill="True">
                                        <Button Content="Add"
                                                MinHeight="0"
                                                MinWidth="0"
                                                Width="45"
                                                Height="22"
                                                DockPanel.Dock="Right"
                                                Margin="8 0 0 0"
                                                Tag="{Binding}"
                                                Click="AddWidget_Click"
                                                Background="#FF7A1A"
                                                Foreground="White"
                                                
                                                />
                                        <TextBlock Text="{Binding Name}"
                                                   Foreground="White"
                                                   VerticalAlignment="Center"/>

                                    </DockPanel>

                                </Border>

                            </DataTemplate>
                        </ListBox.ItemTemplate>

                    </ListBox>

                </ScrollViewer>

            </Grid>

        </Border>

    </Grid>

</UserControl>
