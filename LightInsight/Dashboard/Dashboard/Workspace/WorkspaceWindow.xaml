<Window x:Class="LightInsight.Dashboard.Dashboard.Workspace.WorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Workspace Settings"
        Height="520"
        Width="900"
        Background="#1f2630">

    <!-- ================= STYLES ================= -->
    <Window.Resources>

        <!-- Toolbar Button -->
        <Style x:Key="ToolButton" TargetType="Button">
            <Setter Property="Width" Value="30"/>
            <Setter Property="Height" Value="30"/>
            <Setter Property="Margin" Value="2"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>

            <Style.Triggers>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3b4450"/>
                </Trigger>

            </Style.Triggers>

        </Style>
        <Style TargetType="TreeViewItem">

            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Margin" Value="0,2"/>
            <Setter Property="Padding" Value="4"/>
            <Setter Property="Background" Value="Transparent"/>

            <Setter Property="Template">
                <Setter.Value>

                    <ControlTemplate TargetType="TreeViewItem">

                        <StackPanel>

                            <!-- HEADER -->
                            <Border x:Name="ItemBorder"
                            Background="{TemplateBinding Background}"
                            CornerRadius="4"
                            Padding="4">

                                <ContentPresenter ContentSource="Header"/>

                            </Border>

                            <!-- CHILDREN -->
                            <ItemsPresenter Margin="20,0,0,0"/>

                        </StackPanel>

                        <!-- TRIGGERS -->
                        <ControlTemplate.Triggers>

                            <!-- Hover -->
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <!-- Selected -->
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="#60a5fa"/>
                            </Trigger>

                        </ControlTemplate.Triggers>

                    </ControlTemplate>

                </Setter.Value>
            </Setter>

        </Style>
    </Window.Resources>


    <!-- ================= LAYOUT ================= -->
    <Grid>

        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>


        <!-- ================= TOOLBAR ================= -->
        <Grid Background="#2a323d" Grid.Row="0">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>


            <!-- ICON GROUP -->
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="10,0">

                <!-- Add -->
                <Button Style="{StaticResource ToolButton}" Click="AddWorkspace_Click">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE710;"
                               FontSize="14"/>
                </Button>

                <!-- Edit -->
                <Button Click="EditWorkspace_Click"
                        Tag="{Binding}"
                        x:Name="EditButton"
                        Style="{StaticResource ToolButton}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE70F;"
                               FontSize="12"/>
                </Button>
                <!-- Delete -->
                <Button Click="DeleteWorkspace_Click"
                        Tag="{Binding}"
                        x:Name="DeleteButton"
                        Style="{StaticResource ToolButton}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE74D;"
                               FontSize="12"/>
                </Button>

                <!-- Move Up -->
                <Button Style="{StaticResource ToolButton}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE74A;"
                               FontSize="14"/>
                </Button>

                <!-- Move Down -->
                <Button Style="{StaticResource ToolButton}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE74B;"
                               FontSize="14"/>
                </Button>

                <!-- Copy -->
                <Button Style="{StaticResource ToolButton}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE8C8;"
                               FontSize="14"/>
                </Button>

            </StackPanel>


            <!-- ================= SEARCH ================= -->
            <Border Grid.Column="1"
                    Margin="336,6,10,6"
                    Background="#1f2630"
                    CornerRadius="4">

                <DockPanel LastChildFill="True" Margin="321,0,0,0">

                    <!-- Search Icon -->
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE721;"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="8,0"/>

                    <!-- Search Box -->
                    <TextBox
                        Background="Transparent"
                        BorderThickness="0"
                        Foreground="White"
                        FontSize="14"
                        Width="300"
                        Padding="6"
                        VerticalAlignment="Center"/>

                    <!-- Clear Button -->
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE711;"
                               Foreground="Gray"
                               VerticalAlignment="Center"
                               Margin="8,0"/>

                </DockPanel>

            </Border>

        </Grid>


        <!-- ================= TREE ================= -->
        <Border Grid.Row="1"
        Background="#252c36"
        Padding="10">

            <TreeView x:Name="WorkspaceTree"
              ItemsSource="{Binding Workspaces}"
              Background="Transparent"
              Foreground="White"
              BorderThickness="0">

                <TreeView.ItemTemplate>

                    <HierarchicalDataTemplate ItemsSource="{Binding Children}">

                        <Grid>

                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <!-- ICON -->
                            <iconPacks:PackIconMaterial
                                        Kind="{Binding Icon}"
                                        Width="16"
                                        Height="16"
                                        Margin="0,0,6,0"
                                        Foreground="White"/>

                            <!-- NAME -->
                            <TextBlock Grid.Column="1"
                                       Tag="{Binding Name}"
                                       Text="{Binding Name}"
                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=TreeViewItem}}"
                                       VerticalAlignment="Center"/>

                        </Grid>

                        

                    </HierarchicalDataTemplate>

                </TreeView.ItemTemplate>

            </TreeView>

        </Border>

    </Grid>

</Window>