<Window x:Class="LightInsight.Dashboard.Dashboard.Workspace.AddWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Add Workspace"
        Height="450"
        Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgMain}"
        Foreground="{DynamicResource TextPrimary}"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1"
            CornerRadius="8"
            Background="{DynamicResource BgMain}">

        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <TextBlock Text="Add Workspace"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"
                       Foreground="{DynamicResource TextPrimary}"/>

            <!-- LABEL -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">

                <TextBlock Text="Label"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="12"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="LabelBox"
                         Height="36"
                         Padding="10,5"
                         Background="{DynamicResource CardBg}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource CardBorder}"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"
                         CaretBrush="{DynamicResource TextPrimary}"/>

            </StackPanel>


            <!-- TYPE -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">

                <TextBlock Text="Type"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           Margin="0,0,0,6"/>

                <ComboBox x:Name="TypeBox"
                          Height="36"
                          Background="{DynamicResource CardBg}"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="{DynamicResource CardBorder}"
                          BorderThickness="1">
                    <ComboBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </ComboBox.Resources>
                    <ComboBoxItem Content="Smart Layout" />
                    <ComboBoxItem Content="Dashboard" IsSelected="True"/>
                </ComboBox>

            </StackPanel>


            <!-- ICON PICKER -->
            <StackPanel Grid.Row="3" Margin="0,0,0,20">

                <TextBlock Text="Icon"
                           Foreground="{DynamicResource TextSecondary}"
                           FontSize="12"
                           Margin="0,0,0,6"/>

                <!-- SELECT ICON BUTTON -->
                <Button x:Name="SelectIconButton"
                        Height="36"
                        Background="{DynamicResource CardBg}"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1"
                        Click="SelectIconButton_Click"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                    <StackPanel Orientation="Horizontal">
                        <iconPacks:PackIconMaterial
                                x:Name="SelectedIcon"
                                Kind="ChartLine"
                                Width="18"
                                Height="18"
                                Margin="8,0"
                                Foreground="{DynamicResource AccentColor}"/>

                        <TextBlock x:Name="SelectedIconName" 
                                   Text="Select icon"
                                   VerticalAlignment="Center"
                                   Margin="4,0"
                                   Foreground="{DynamicResource TextPrimary}"/>
                    </StackPanel>
                </Button>


                <!-- POPUP ICON PICKER -->
                <Popup x:Name="IconPopup"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=SelectIconButton}"
                       StaysOpen="False"
                       AllowsTransparency="True">

                    <Border Background="{DynamicResource CardBg}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Width="330"
                            Height="300"
                            Padding="10"
                            Margin="0,5,0,0">
                        <Border.Effect>
                            <DropShadowEffect BlurRadius="15" Opacity="0.3" ShadowDepth="5"/>
                        </Border.Effect>

                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- SEARCH -->
                            <Border Background="{DynamicResource BgMain}" 
                                    BorderBrush="{DynamicResource CardBorder}" 
                                    BorderThickness="1" 
                                    CornerRadius="4" 
                                    Margin="0,0,0,10">
                                <Grid Height="35">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="35"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <iconPacks:PackIconMaterial Kind="Magnify" Foreground="{DynamicResource TextSecondary}" Width="14" Height="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    <TextBox Grid.Column="1" x:Name="IconSearchBox"
                                             Background="Transparent"
                                             Foreground="{DynamicResource TextPrimary}"
                                             BorderThickness="0"
                                             KeyDown="IconSearchBox_KeyDown"
                                             Padding="5,0"
                                             VerticalContentAlignment="Center"
                                             CaretBrush="{DynamicResource TextPrimary}"/>
                                </Grid>
                            </Border>

                            <!-- ICON LIST -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <ListBox x:Name="IconList"
                                         Background="Transparent"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         BorderThickness="0"
                                         ScrollViewer.CanContentScroll="True"
                                         SelectionChanged="IconList_SelectionChanged">
                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="6"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>

                                    <ListBox.ItemContainerStyle>
                                        <Style TargetType="ListBoxItem">
                                            <Setter Property="Width" Value="42"/>
                                            <Setter Property="Height" Value="42"/>
                                            <Setter Property="Margin" Value="3"/>
                                            <Setter Property="Padding" Value="0"/>
                                            <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                            <Setter Property="Template">
                                                <Setter.Value>
                                                    <ControlTemplate TargetType="ListBoxItem">
                                                        <Border x:Name="IconBorder"
                                                                Background="Transparent"
                                                                CornerRadius="4"
                                                                BorderThickness="1"
                                                                BorderBrush="Transparent">
                                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="IconBorder" Property="Background" Value="{DynamicResource ButtonBgHover}"/>
                                                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                                                            </Trigger>
                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="IconBorder" Property="Background" Value="{DynamicResource AccentColor}"/>
                                                                <Setter TargetName="IconBorder" Property="BorderBrush" Value="{DynamicResource AccentHover}"/>
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </Setter.Value>
                                            </Setter>
                                        </Style>
                                    </ListBox.ItemContainerStyle>

                                    <ListBox.ItemTemplate>
                                        <DataTemplate>
                                            <iconPacks:PackIconMaterial Kind="{Binding}" Width="18" Height="18" Foreground="{DynamicResource TextPrimary}"/>
                                        </DataTemplate>
                                    </ListBox.ItemTemplate>
                                </ListBox>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Popup>

            </StackPanel>


            <!-- BUTTONS -->
            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,10,0,0">

                <Button Content="Cancel"
                        Width="90"
                        Height="34"
                        Margin="0,0,10,0"
                        Background="{DynamicResource ButtonBg}"
                        Foreground="{DynamicResource TextSecondary}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1"
                        Click="Cancel_Click"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                    </Button.Resources>
                </Button>

                <Button Content="Save"
                        Width="100"
                        Height="34"
                        Background="{DynamicResource AccentColor}"
                        Foreground="White"
                        BorderThickness="0"
                        Click="Create_Click"
                        FontWeight="SemiBold"
                        Cursor="Hand">
                    <Button.Resources>
                        <Style TargetType="Border"><Setter Property="CornerRadius" Value="4"/></Style>
                    </Button.Resources>
                </Button>

            </StackPanel>

        </Grid>

    </Border>

</Window>