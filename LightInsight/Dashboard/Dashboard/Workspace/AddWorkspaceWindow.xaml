<Window x:Class="LightInsight.Dashboard.Dashboard.Workspace.AddWorkspaceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:iconPacks="http://metro.mahapps.com/winfx/xaml/iconpacks"
        Title="Add Workspace"
        Height="450"
        Width="380"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource BgMain}"
        Foreground="{DynamicResource TextPrimary}"
        ResizeMode="NoResize"
        WindowStyle="None"
        AllowsTransparency="True">

    <Border BorderBrush="{DynamicResource CardBorder}"
            BorderThickness="1"
            CornerRadius="8">

        <Grid Margin="24">

            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- TITLE -->
            <TextBlock Text="Add Workspace"
                       FontSize="18"
                       FontWeight="SemiBold"
                       Margin="0,0,0,20"
                       Foreground="{DynamicResource TextPrimary}"/>

            <!-- LABEL -->
            <StackPanel Grid.Row="1" Margin="0,0,0,15">

                <TextBlock Text="Label"
                           Foreground="{DynamicResource TextPrimary}"
                           FontSize="12"
                           Margin="0,0,0,6"/>

                <TextBox x:Name="LabelBox"
                         Height="36"
                         Padding="10,5"
                         Background="{DynamicResource BgMain}"
                         Foreground="{DynamicResource TextPrimary}"
                         BorderBrush="{DynamicResource CardBorder}"
                         BorderThickness="1"
                         VerticalContentAlignment="Center"/>

            </StackPanel>


            <!-- TYPE -->
            <StackPanel Grid.Row="2" Margin="0,0,0,15">

                <TextBlock Text="Type"
                           Foreground="#9ca3af"
                           FontSize="12"
                           Margin="0,0,0,6"/>

                <ComboBox x:Name="TypeBox"
                          Height="36"
                          Background="{DynamicResource BgMain}"
                          Foreground="{DynamicResource TextPrimary}"
                          BorderBrush="{DynamicResource CardBorder}"
                          BorderThickness="1">

                    <ComboBoxItem Content="Smart Layout" />
                    <ComboBoxItem Content="Dashboard" IsSelected="True"/>

                </ComboBox>

            </StackPanel>


            <!-- ICON PICKER -->
            <StackPanel Grid.Row="3" Margin="0,0,0,20">

                <TextBlock Text="Icon"
                           Foreground="#9ca3af"
                           FontSize="12"
                           Margin="0,0,0,6"/>

                <!-- SELECT ICON BUTTON -->
                <Button x:Name="SelectIconButton"
                        Height="36"
                        Background="{DynamicResource BgMain}"
                        BorderBrush="{DynamicResource CardBorder}"
                        BorderThickness="1"
                        Click="SelectIconButton_Click">

                    <StackPanel Orientation="Horizontal">

                        <iconPacks:PackIconMaterial
                                x:Name="SelectedIcon"
                                Kind="ChartLine"
                                Width="20"
                                Height="20"
                                Margin="8,0"/>

                        <TextBlock x:Name="SelectedIconName" 
                                   Text="Select icon"
                                   VerticalAlignment="Center"
                                   Margin="8,0"/>

                    </StackPanel>

                </Button>


                <!-- POPUP ICON PICKER -->
                <Popup x:Name="IconPopup"
                       Placement="Bottom"
                       PlacementTarget="{Binding ElementName=SelectIconButton}"
                       StaysOpen="False">

                    <Border Background="{DynamicResource BgMain}"
                            BorderBrush="{DynamicResource CardBorder}"
                            BorderThickness="1"
                            CornerRadius="6"
                            Width="330"
                            Height="300"
                            Padding="10">

                        <Grid>

                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- SEARCH -->
                            <TextBox x:Name="IconSearchBox"
                                     Height="35"
                                     Margin="0,0,0,10"
                                     Background="{DynamicResource BgMain}"
                                     Foreground="{DynamicResource TextPrimary}"
                                     BorderBrush="{DynamicResource CardBorder}"
                                     KeyDown="IconSearchBox_KeyDown"
                                     Padding="8"/>


                            <!-- ICON LIST -->
                            <ScrollViewer Grid.Row="1">

                                <ListBox x:Name="IconList"
                                         Background="{DynamicResource CardBorder}"
                                         VirtualizingPanel.IsVirtualizing="True"
                                         VirtualizingPanel.VirtualizationMode="Recycling"
                                         BorderThickness="0"
                                         ScrollViewer.CanContentScroll="True"
                                         SelectionChanged="IconList_SelectionChanged">

                                    <ListBox.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <UniformGrid Columns="6"/>
                                        </ItemsPanelTemplate>
                                    </ListBox.ItemsPanel>

                                    <ListBox.ItemContainerStyle>

                                        <Style TargetType="ListBoxItem">

                                            <Setter Property="Width" Value="40"/>
                                            <Setter Property="Height" Value="40"/>
                                            <Setter Property="Margin" Value="4"/>

                                            <Setter Property="Template">
                                                <Setter.Value>

                                                    <ControlTemplate TargetType="ListBoxItem">

                                                        <Border x:Name="IconBorder"
                                                                Background="{DynamicResource ButtonBg}"
                                                                CornerRadius="4">

                                                            <ContentPresenter
                                                                HorizontalAlignment="Center"
                                                                VerticalAlignment="Center"/>

                                                        </Border>

                                                        <ControlTemplate.Triggers>

                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="IconBorder"
                                                                        Property="Background"
                                                                        Value="{DynamicResource TextPrimary}"/>
                                                            </Trigger>

                                                            <Trigger Property="IsSelected" Value="True">
                                                                <Setter TargetName="IconBorder"
                                                                        Property="Background"
                                                                        Value="{DynamicResource TextPrimary}"/>
                                                            </Trigger>

                                                        </ControlTemplate.Triggers>

                                                    </ControlTemplate>

                                                </Setter.Value>
                                            </Setter>

                                        </Style>

                                    </ListBox.ItemContainerStyle>


                                    <ListBox.ItemTemplate>

                                        <DataTemplate>

                                            <iconPacks:PackIconMaterial
                                                    Kind="{Binding}"
                                                    Width="20"
                                                    Height="20"
                                                    Foreground="White"/>

                                        </DataTemplate>

                                    </ListBox.ItemTemplate>

                                </ListBox>

                            </ScrollViewer>

                        </Grid>

                    </Border>

                </Popup>

            </StackPanel>


            <!-- BUTTONS -->
            <StackPanel Grid.Row="5"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">

                <Button Content="Cancel"
                        Width="90"
                        Height="34"
                        Margin="0,0,10,0"
                        Background="{DynamicResource ButtonBg}"
                        Foreground="#9ca3af"
                        BorderThickness="0"
                        Click="Cancel_Click"/>

                <Button Content="Save"
                        Width="100"
                        Height="34"
                        Background="{DynamicResource ButtonBg}"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderThickness="0"
                        Click="Create_Click"/>

            </StackPanel>

        </Grid>

    </Border>

</Window>