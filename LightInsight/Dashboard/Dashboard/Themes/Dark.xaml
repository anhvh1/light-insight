<ResourceDictionary x:Class="LightInsight.Dashboard.Dashboard.Themes.Dark"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ===== BACKGROUND ===== -->
    <SolidColorBrush x:Key="BgMain" Color="#1E2128"/>
    <SolidColorBrush x:Key="CardBg" Color="#272B34"/>
    <SolidColorBrush x:Key="ToolbarBg" Color="#272B34"/>

    <!-- ===== BORDER ===== -->
    <SolidColorBrush x:Key="CardBorder" Color="#363B46"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#363B46"/>

    <!-- ===== TEXT ===== -->
    <SolidColorBrush x:Key="TextPrimary" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TextMuted" Color="#7A8090"/>

    <!-- ===== ACCENT ===== -->
    <SolidColorBrush x:Key="AccentColor" Color="#E8751A"/>
    <SolidColorBrush x:Key="AccentHover" Color="#F2943B"/>

    <!-- (giữ từ bản 1 vì bản 2 không có) -->
    <SolidColorBrush x:Key="AccentBlue"    Color="#60A5FA"/>
    <SolidColorBrush x:Key="AccentGreen"   Color="#22C55E"/>
    <SolidColorBrush x:Key="AccentPurple"  Color="#7A8090"/>
    <SolidColorBrush x:Key="AccentOrange"  Color="#E8751A"/>
    <SolidColorBrush x:Key="AccentCyan"    Color="#60A5FA"/>

    <!-- ===== STATUS ===== -->
    <SolidColorBrush x:Key="StatusOnline"  Color="#22C55E"/>
    <SolidColorBrush x:Key="StatusOffline" Color="#EF4444"/>
    <SolidColorBrush x:Key="StatusWarning" Color="#F59E0B"/>

    <!-- ===== BUTTONS ===== -->
    <SolidColorBrush x:Key="ButtonBg"        Color="#1E2128"/>
    <SolidColorBrush x:Key="ButtonBgHover"   Color="#333842"/>
    <SolidColorBrush x:Key="ButtonBgPressed" Color="#363B46"/>

    <!-- ===== HOVER ===== -->
    <SolidColorBrush x:Key="ItemHoverBg" Color="#333842"/>
    <SolidColorBrush x:Key="RowHoverBg"  Color="#333842"/>

    <!-- ===== SIDEBAR ===== -->
    <SolidColorBrush x:Key="SidebarHeaderBackgroundBrush" Color="#2A2F3A"/>

    <!-- ===== CARD STYLE ===== -->
    <Thickness x:Key="CardBorderThickness">1</Thickness>
    <x:Null x:Key="CardShadow"/>

    <!-- ===== WIDGET ===== -->
    <SolidColorBrush x:Key="WidgetCardBg"        Color="#272B34"/>
    <SolidColorBrush x:Key="WidgetHeaderBg"      Color="#2C3039"/>
    <SolidColorBrush x:Key="WidgetHeaderText"    Color="#FFFFFF"/>
    <SolidColorBrush x:Key="WidgetBorder"        Color="#363B46"/>
    <SolidColorBrush x:Key="WidgetAccentBorder"  Color="#E8751A"/>
    <SolidColorBrush x:Key="WidgetResizeThumb"   Color="#7A8090"/>

    <!-- ===== ICON TILE ===== -->
    <SolidColorBrush x:Key="IconBgDevices"  Color="#2C3039"/>
    <SolidColorBrush x:Key="IconBgVisitor"  Color="#2A2518"/>
    <SolidColorBrush x:Key="IconBgVehicles" Color="#1E2128"/>
    <SolidColorBrush x:Key="IconBgWarning"  Color="#2A2518"/>

    <!-- ===== STATUS TILE / BADGE ===== -->
    <SolidColorBrush x:Key="StatusTileOkBg"    Color="#2C3039"/>
    <SolidColorBrush x:Key="StatusTileErrorBg" Color="#2A2518"/>
    <SolidColorBrush x:Key="BadgeErrorBg"      Color="#EF4444"/>
    <SolidColorBrush x:Key="BadgeErrorText"    Color="#FFFFFF"/>

    <!-- ===== TABLE ===== -->
    <SolidColorBrush x:Key="TableHeaderBg"   Color="#2C3039"/>
    <SolidColorBrush x:Key="TableHeaderText" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="TableRowAltBg"   Color="#272B34"/>

    <!-- Status Badges for Tables -->
    <SolidColorBrush x:Key="StatusOnlineBg"     Color="#1A3A26"/>
    <SolidColorBrush x:Key="StatusOnlineText"   Color="#4ADE80"/>
    <SolidColorBrush x:Key="StatusOfflineBg"    Color="#4D1F1F"/>
    <SolidColorBrush x:Key="StatusOfflineText"  Color="#F87171"/>

    <!-- ===== LIVECHARTS ===== -->
    <SolidColorBrush x:Key="ChartGuestStroke"   Color="#EF4444"/>
    <SolidColorBrush x:Key="ChartGuestFill"     Color="#00000000"/>
    <SolidColorBrush x:Key="ChartVehicleStroke" Color="#22C55E"/>
    <SolidColorBrush x:Key="ChartVehicleFill"   Color="#6622C55E"/>
    <SolidColorBrush x:Key="ChartEventStroke"   Color="#E8751A"/>
    <SolidColorBrush x:Key="ChartEventFill"     Color="#66E8751A"/>

    <!-- ===== LOGO ===== -->
    <ImageSource x:Key="CompanyLogo">/LightInsight;component/Dashboard/Asset/logo.png</ImageSource>
    <SolidColorBrush x:Key="LogoPlateBg" Color="Transparent"/>

</ResourceDictionary>