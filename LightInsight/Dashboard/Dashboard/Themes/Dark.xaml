<ResourceDictionary x:Class="LightInsight.Dashboard.Dashboard.Themes.Dark"
                    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Core -->
    <SolidColorBrush x:Key="BgMain"        Color="#0F172A"/>
    <SolidColorBrush x:Key="CardBg"        Color="#1E293B"/>
    <SolidColorBrush x:Key="TextPrimary"   Color="#F1F5F9"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#94A3B8"/>

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentBlue"    Color="#3B82F6"/>
    <SolidColorBrush x:Key="AccentGreen"   Color="#10B981"/>
    <SolidColorBrush x:Key="AccentPurple"  Color="#A855F7"/>
    <SolidColorBrush x:Key="AccentOrange"  Color="#F59E0B"/>
    <SolidColorBrush x:Key="AccentCyan"    Color="#06B6D4"/>

    <!-- Status -->
    <SolidColorBrush x:Key="StatusOnline"  Color="#34D399"/>
    <SolidColorBrush x:Key="StatusOffline" Color="#EF4444"/>

    <!-- Buttons & states -->
    <SolidColorBrush x:Key="ButtonBg"        Color="#334155"/>
    <SolidColorBrush x:Key="ButtonBgHover"   Color="#475569"/>
    <SolidColorBrush x:Key="ButtonBgPressed" Color="#1E293B"/>

    <!-- Hover / separators -->
    <SolidColorBrush x:Key="ItemHoverBg"    Color="#334155"/>
    <SolidColorBrush x:Key="RowHoverBg"     Color="#1A3A52"/>
    <SolidColorBrush x:Key="SeparatorBrush" Color="#334155"/>

    <!-- Card viền & bóng (dark dùng viền mảnh, không bóng) -->
    <SolidColorBrush x:Key="CardBorder" Color="#263241"/>
    <Thickness      x:Key="CardBorderThickness">1</Thickness>
    <x:Null         x:Key="CardShadow"/>

    <!-- Widget (riêng cho card + label/header) -->
    <SolidColorBrush x:Key="WidgetCardBg"        Color="#1A2332"/>
    <SolidColorBrush x:Key="WidgetHeaderBg"      Color="#141D2B"/>
    <SolidColorBrush x:Key="WidgetHeaderText"    Color="#E2E8F0"/>
    <SolidColorBrush x:Key="WidgetBorder"        Color="#2A3A4E"/>
    <SolidColorBrush x:Key="WidgetAccentBorder"  Color="#E8751A"/>
    <SolidColorBrush x:Key="WidgetResizeThumb"   Color="#94A3B8"/>

    <!-- Icon tile -->
    <SolidColorBrush x:Key="IconBgDevices"  Color="#1E3A8A"/>
    <SolidColorBrush x:Key="IconBgVisitor"  Color="#065F46"/>
    <SolidColorBrush x:Key="IconBgVehicles" Color="#581C87"/>
    <SolidColorBrush x:Key="IconBgWarning"  Color="#92400E"/>

    <!-- Status tiles / badges -->
    <SolidColorBrush x:Key="StatusTileOkBg"     Color="#065F46"/>
    <SolidColorBrush x:Key="StatusTileErrorBg"  Color="#7F1D1D"/>
    <SolidColorBrush x:Key="BadgeErrorBg"       Color="#991B1B"/>
    <SolidColorBrush x:Key="BadgeErrorText"     Color="#FCA5A5"/>

    <!-- Table -->
    <SolidColorBrush x:Key="TableHeaderBg"   Color="#1F2A3A"/>
    <SolidColorBrush x:Key="TableHeaderText" Color="#94A3B8"/>
    <SolidColorBrush x:Key="TableRowAltBg"   Color="#172131"/>

    <!-- LiveCharts -->
    <SolidColorBrush x:Key="ChartGuestStroke"    Color="#4FC3F7"/>
    <SolidColorBrush x:Key="ChartGuestFill"      Color="#994FC3F7"/>
    <SolidColorBrush x:Key="ChartVehicleStroke"  Color="#00E676"/>
    <SolidColorBrush x:Key="ChartVehicleFill"    Color="#9900E676"/>
    <SolidColorBrush x:Key="ChartEventStroke"    Color="#FFB300"/>
    <SolidColorBrush x:Key="ChartEventFill"      Color="#99FFB300"/>
    <SolidColorBrush x:Key="ChartGridBrush"      Color="#334155"/>

    <ImageSource x:Key="CompanyLogo">/LightInsight;component/Dashboard/Asset/logo.png"</ImageSource>
    <SolidColorBrush x:Key="LogoPlateBg" Color="#00000000"/>

</ResourceDictionary>
