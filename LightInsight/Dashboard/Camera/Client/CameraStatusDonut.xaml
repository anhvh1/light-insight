<UserControl x:Class="LightInsight.Dashboard.Camera.Client.CameraStatusDonut"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="150"
             Width="300">

	<Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0">
		<Border.BorderBrush>
			<VisualBrush>
				<VisualBrush.Visual>
					<Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
				</VisualBrush.Visual>
			</VisualBrush>
		</Border.BorderBrush>

		<Grid>
			<Border Background="#3E3E42"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,0,0,1"
                    Height="25"
                    VerticalAlignment="Top"
                    Padding="10,0,0,0"
                    CornerRadius="6,6,0,0">
				<TextBlock Text="Camera Status Donut"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"/>
			</Border>

			<Button x:Name="DeleteButton"
                    Content="X"
                    Width="30" Height="23"
                    MinWidth="0" MinHeight="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    FontSize="16"
                    Click="DeleteWidget_Click"/>

			<Grid Margin="0,25,0,0">
				<Ellipse x:Name="BackgroundCircle"
                         Stroke="#F44336"
                         StrokeThickness="18"
                         Width="100" Height="100"/>

				<Ellipse x:Name="OnlineSlice"
                         Stroke="#2ECC71"
                         StrokeThickness="18"
                         Width="100" Height="100"
                         StrokeDashArray="0, 100"
                         RenderTransformOrigin="0.5,0.5"
                         >
					<Ellipse.RenderTransform>
						<TransformGroup>
							<ScaleTransform ScaleX="-1" ScaleY="1"/>
							<RotateTransform Angle="0"/>
						</TransformGroup>
					</Ellipse.RenderTransform>
				</Ellipse>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="15,0,0,0">
					<TextBlock Text="Online: " Foreground="#2ECC71" FontSize="16"/>
					<TextBlock x:Name="TxtOnline" Text="0" Foreground="#2ECC71" FontSize="16" FontWeight="Bold"/>
				</StackPanel>

				<StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,15,0">
					<TextBlock x:Name="LblOffline" Text="Offline: " Foreground="#F44336" FontSize="16"/>
					<TextBlock x:Name="TxtOffline" Text="0" Foreground="#F44336" FontSize="16" FontWeight="Bold"/>
				</StackPanel>
			</Grid>
		</Grid>
	</Border>
</UserControl>