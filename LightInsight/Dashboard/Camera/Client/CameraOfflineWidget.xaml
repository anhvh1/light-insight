<UserControl x:Class="LightInsight.Dashboard.Camera.Client.CameraOfflineWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="130"
             Width="200">

    <Border Background="#2D2D30"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">

        <Grid>
            <Button x:Name="DeleteButton"
                Content="X"
                Width="15" 
                Height="15"
                MinWidth="0"   
                MinHeight="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                HorizontalContentAlignment="Center" 
                VerticalContentAlignment="Center"
                Padding="0" 
                FontSize="10"
                Click="DeleteWidget_Click"/>

            <StackPanel Margin="0 10 0 0">
                <TextBlock Text="Camera Offline Count"
                           Foreground="White"
                           FontSize="14"
                           Margin="0 0 0 5"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" 
                               Text="&#xEB55;" 
                               FontSize="24" 
                               Foreground="#FF8080"
                               VerticalAlignment="Center"
                               Margin="0 0 10 0"/>

                    <TextBlock Text="8"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#FF8080"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Cameras Offline"
                           Foreground="LightGray"/>

                <TextBlock Text="↘ 15% vs last period"
                           Foreground="#EF4444" 
                           FontSize="11"/>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>