<UserControl x:Class="LightInsight.Dashboard.Camera.Client.CameraAnalyticsSummaryWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Tag="1x1"             
             Width="Auto" Height="Auto" 
             HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch">
	<Viewbox Stretch="Fill">

		<Grid Width="240" Height="150">
			<Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0">
				<Border.BorderBrush>
					<VisualBrush>
						<VisualBrush.Visual>
							<Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
						</VisualBrush.Visual>
					</VisualBrush>
				</Border.BorderBrush>

				<Grid>
					<Border Background="#3E3E42"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,0,0,1"
                    Height="25"
                    VerticalAlignment="Top"
                    Padding="10,0,0,0"
                    CornerRadius="6,6,0,0">
				<TextBlock Text="Camera Analytics Summary"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"/>
					</Border>

					<Button x:Name="DeleteButton"
                    Content="X"
                    Width="30" Height="23"
                    MinWidth="0" MinHeight="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    FontSize="16"
                    Click="DeleteWidget_Click"/>

					<StackPanel Margin="4 40 0 0">

						<StackPanel Orientation="Horizontal" VerticalAlignment="Center">

							<TextBlock FontFamily="Segoe MDL2 Assets" 
                               Text="&#xE722;" 
                               FontSize="24" 
                               Foreground="LimeGreen"
                               VerticalAlignment="Center"
                               Margin="0 0 10 0"/>

							<TextBlock Text="142"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="LimeGreen"
                               VerticalAlignment="Center"/>
						</StackPanel>

						<TextBlock Text="Cameras Online"
                           Foreground="LightGray"
                           FontSize="16"/>

						<TextBlock Text="↗ 2.3% vs last period"
                           Foreground="LimeGreen"
                           FontSize="12"/>

					</StackPanel>
				</Grid>
			</Border>
			<Thumb x:Name="ResizeThumb" 
                Width="12" Height="12" 
                Cursor="SizeNWSE"
                VerticalAlignment="Bottom" 
                HorizontalAlignment="Right"
                Background="Transparent">
				<Thumb.Template>
					<ControlTemplate>
						<Path Data="M 12,0 L 12,12 L 0,12 Z" Fill="#888" Opacity="0.5"/>
					</ControlTemplate>
				</Thumb.Template>
			</Thumb>
		</Grid>
	</Viewbox>
</UserControl>