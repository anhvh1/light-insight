<UserControl x:Class="LightInsight.Dashboard.Camera.Client.CameraOnlineNOffline"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="130"
             Width="200">

	<Border Background="#2D2D30"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">

		<Grid>
			<Button x:Name="DeleteButton"
                    Content="X"
                    Width="15" 
                    Height="15"
                    MinWidth="0"   
                    MinHeight="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    HorizontalContentAlignment="Center" 
                    VerticalContentAlignment="Center"
                    Padding="0" 
                    FontSize="10"
                    Click="DeleteWidget_Click"/>

			<StackPanel Margin="0 10 0 0">

				<TextBlock Text="Camera Online + Offline"
                           Foreground="White"
                           FontSize="14"
                           Margin="0 0 0 5"/>

				<StackPanel Orientation="Horizontal" VerticalAlignment="Center">
					<StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
						<TextBlock x:Name="TxtOnlineCount"
                                   Text="142"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#7DB8FF" 
                                   VerticalAlignment="Center"/>

						<TextBlock Text=" / "
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="White"
                                   VerticalAlignment="Center"
                                   Margin="5 0"/>

						<TextBlock x:Name="TxtOfflineCount"
                                   Text="8"
                                   FontSize="32"
                                   FontWeight="Bold"
                                   Foreground="#7DB8FF"
                                   VerticalAlignment="Center"/>
					</StackPanel>
				</StackPanel>

				<TextBlock Text="Online / Offline"
                           FontSize="16"
                           Foreground="LightGray"
                           Margin="8 0 0 0"/>

			</StackPanel>
		</Grid>
	</Border>
</UserControl>