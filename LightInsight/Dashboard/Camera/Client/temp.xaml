<UserControl x:Class="LightInsight.Dashboard.Camera.Client.temp"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="150"
             MinHeight="100" MinWidth="150">
	<Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0">
		<Border.BorderBrush>
			<VisualBrush>
				<VisualBrush.Visual>
					<Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
				</VisualBrush.Visual>
			</VisualBrush>
		</Border.BorderBrush>

		<Grid>
			<Border Background="#3E3E42"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,0,0,1"
                    Height="25"
                    VerticalAlignment="Top"
                    Padding="10,0,0,0"
                    CornerRadius="6,6,0,0">
				<TextBlock Text="Camera Status Donut"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"/>
			</Border>

			<Button x:Name="DeleteButton"
                    Content="X"
                    Width="30" Height="23"
                    MinWidth="0" MinHeight="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    FontSize="16"
                    Click="DeleteWidget_Click"/>

			<Thumb x:Name="ResizeThumb" 
                   Width="10" Height="10" 
                   Cursor="SizeNWSE" 
                   VerticalAlignment="Bottom" 
                   HorizontalAlignment="Right"
                   DragDelta="ResizeThumb_DragDelta">
				<Thumb.Template>
					<ControlTemplate>
						<Grid Background="Transparent">
							<Path Data="M 8,0 L 8,8 L 0,8 Z" Fill="#55FFFFFF" Margin="0,0,1,1" VerticalAlignment="Bottom" HorizontalAlignment="Right"/>
						</Grid>
					</ControlTemplate>
				</Thumb.Template>
			</Thumb>
		</Grid>
	</Border>
</UserControl>