<UserControl x:Class="LightInsight.Dashboard.Camera.Client.CameraOnlineWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Tag="2x2"
             Width="Auto" Height="Auto" 
             HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid Margin="5,5,0,0">
        <Border Background="{DynamicResource BgMain}" BorderThickness="1" CornerRadius="6" x:Name="MainBorder">
            <Border.BorderBrush>
                <VisualBrush Stretch="None">
                    <VisualBrush.Visual>
                        <Rectangle Stroke="#E8751A"
                                   StrokeDashArray="4 2"
                                   StrokeThickness="1"
                                   RadiusX="6" RadiusY="6"
                                   Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
                                   Height="{Binding ElementName=MainBorder, Path=ActualHeight}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.BorderBrush>

		    <Grid>
			    <Border Background="{DynamicResource WidgetHeaderBg}" Height="25" VerticalAlignment="Top" CornerRadius="6,6,6,6" BorderBrush="{DynamicResource WidgetBorder}" BorderThickness="0,0,0,1">
                    <TextBlock Text="{DynamicResource Camera_Label_CamerasOnline}" Foreground="{DynamicResource WidgetHeaderText}" FontSize="14" VerticalAlignment="Center"/>
			    </Border>

                <Button x:Name="DeleteButton" 
                        Content="X" 
                        Width="20" Height="20" 
                        MinWidth="20" MinHeight="20"
                        MaxWidth="20" MaxHeight="20"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="0,3,3,0"
                        Padding="0"
                        Background="{DynamicResource ButtonBg}"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderThickness="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="DeleteWidget_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </Button.Resources>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder"
                                    
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/> </Trigger>
                
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                <Viewbox Stretch="Uniform" Margin="10,35,10,10" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <StackPanel Width="220">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

					        <TextBlock FontFamily="Segoe MDL2 Assets" 
                                       Text="&#xE722;" 
                                       FontSize="24" 
                                       Foreground="#4ADE80"
                                       VerticalAlignment="Center"
                                       Margin="0 0 10 0"/>

					        <TextBlock x:Name="TxtOnlineCount"
                                       Text="0"
                                       FontSize="32"
                                       FontWeight="Bold"
                                       Foreground="#4ADE80"
                                       VerticalAlignment="Center"/>
				        </StackPanel>

				        <TextBlock Text="{DynamicResource Camera_Label_CamerasOnline}"
                                   Foreground="{DynamicResource TextPrimary}"
                                   FontSize="16"/>

				        <!-- <TextBlock Text="↗ 2.3% vs last period"
                                   Foreground="LimeGreen"
                                   FontSize="12"/>  -->
                    </StackPanel>
                </Viewbox>

                <Thumb x:Name="InternalResizeThumb" Width="12" Height="12" Cursor="SizeNWSE" VerticalAlignment="Bottom" HorizontalAlignment="Right" Background="Transparent">
                    <Thumb.Template>
                        <ControlTemplate>
                            <Path Data="M 12,0 L 12,12 L 0,12 Z" Fill="#888" Opacity="0.5"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

		    </Grid>
	    </Border>
     </Grid>
</UserControl>