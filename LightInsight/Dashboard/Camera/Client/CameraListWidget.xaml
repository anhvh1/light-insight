<UserControl x:Class="LightInsight.Dashboard.Camera.Client.CameraListWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Tag="12x4"
             Width="Auto" Height="Auto" 
             HorizontalAlignment="Stretch" 
             VerticalAlignment="Stretch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

	<UserControl.Resources>
		<Style x:Key="TabButtonStyle" TargetType="RadioButton">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="RadioButton">
						<Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="8,2">
							<ContentPresenter />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="bg" Property="Background" Value="#E8751A"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
			<Setter Property="FontSize" Value="11"/>
		</Style>
		<Style x:Key="PageButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
			<Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
			<Setter Property="Width" Value="22"/>
			<Setter Property="Height" Value="22"/>
			<Setter Property="Margin" Value="2,0"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="2">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
				</Trigger>
			</Style.Triggers>
		</Style>
	</UserControl.Resources>

	    <Grid Margin="5,5,0,0">
        <Border Background="{DynamicResource BgMain}" BorderThickness="1" CornerRadius="6" x:Name="MainBorder">
            <Border.BorderBrush>
                <VisualBrush Stretch="None">
                    <VisualBrush.Visual>
                        <Rectangle Stroke="#E8751A"
                                   StrokeDashArray="4 2"
                                   StrokeThickness="1"
                                   RadiusX="6" RadiusY="6"
                                   Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
                                   Height="{Binding ElementName=MainBorder, Path=ActualHeight}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.BorderBrush>

		    <Grid>
			    <Border Background="{DynamicResource BgMain}" Height="25" VerticalAlignment="Top" CornerRadius="6,6,6,6">
				    <TextBlock Text="{DynamicResource WidgetName_CameraList}" Foreground="{DynamicResource TextPrimary}" FontSize="14" VerticalAlignment="Center"/>
			    </Border>

                <Button x:Name="DeleteButton" 
                        Content="X" 
                        Width="20" Height="20" 
                        MinWidth="20" MinHeight="20"
                        MaxWidth="20" MaxHeight="20"
                        HorizontalAlignment="Right" 
                        VerticalAlignment="Top" 
                        Margin="0,3,3,0"
                        Padding="0"
                        Background="{DynamicResource ButtonBg}"
                        FontSize="12"
                        FontWeight="Bold"
                        Foreground="{DynamicResource TextPrimary}"
                        BorderThickness="0"
                        HorizontalContentAlignment="Center"
                        VerticalContentAlignment="Center"
                        Click="DeleteWidget_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="2"/>
                        </Style>
                    </Button.Resources>
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="btnBorder"
                                    
                                    Background="{TemplateBinding Background}" 
                                    BorderBrush="{TemplateBinding BorderBrush}" 
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>

                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/> </Trigger>
                
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="btnBorder" Property="Background" Value="{DynamicResource ButtonBg}"/>
                                    <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
                
                <Grid Margin="10,35,10,10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/> <RowDefinition Height="*"/>    <RowDefinition Height="Auto"/> </Grid.RowDefinitions>

                    <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                            <RadioButton Content="{DynamicResource Camera_Filter_All8}" Style="{StaticResource TabButtonStyle}" IsChecked="True" Margin="0,0,5,0"/>
                            <RadioButton Content="{DynamicResource Camera_Filter_Online6}" Style="{StaticResource TabButtonStyle}" Margin="0,0,5,0"/>
                            <RadioButton Content="{DynamicResource Camera_Filter_Offline2}" Style="{StaticResource TabButtonStyle}"/>
                        </StackPanel>
                        <Border DockPanel.Dock="Right" Background="{DynamicResource BgMain}" CornerRadius="4" Width="180" Height="22">
                            <Grid>
                                <TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Foreground="{DynamicResource TextPrimary}" 
                                         VerticalContentAlignment="Center" Padding="5,0,25,0" FontSize="11" KeyDown="SearchBox_KeyDown"/>
                                <TextBlock Text="🔍" Foreground="{DynamicResource TextPrimary}" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,5,0" Cursor="Hand" MouseDown="SearchIcon_MouseDown"/>
                            </Grid>
                        </Border>
                    </DockPanel>

                    <DataGrid Grid.Row="1" x:Name="CameraDataGrid" 
                              Background="Transparent" Foreground="{DynamicResource TextPrimary}" RowBackground="Transparent"
                              BorderThickness="0" GridLinesVisibility="None" AutoGenerateColumns="False"
                              CanUserAddRows="False" IsReadOnly="True" RowHeaderWidth="0"
                              HeadersVisibility="Column"
                              HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
                        <DataGrid.Resources>
                            <!-- Style chung cho toàn bộ Header của DataGrid này -->
                            <Style TargetType="DataGridColumnHeader">
                                <Setter Property="Background" Value="{DynamicResource TableHeaderBg}"/>
                                <Setter Property="Foreground" Value="{DynamicResource TableHeaderText}"/>
                                <Setter Property="Padding" Value="10,5"/>
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource CardBorder}"/>
                                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                            </Style>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Binding="{Binding ID}" Width="80">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Content" Value="{DynamicResource Camera_GridHeader_ID}" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding Name}" Width="*">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Content" Value="{DynamicResource Camera_GridHeader_NAME}" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>

                            <DataGridTemplateColumn Width="90">
                                <DataGridTemplateColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Content" Value="{DynamicResource Camera_GridHeader_STATUS}" />
                                    </Style>
                                </DataGridTemplateColumn.HeaderStyle>
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <Border x:Name="StatusBadge" CornerRadius="10" Padding="8,2" HorizontalAlignment="Center" MinWidth="60">
                                            <TextBlock x:Name="StatusText" Text="{Binding Status}" FontSize="10" FontWeight="SemiBold" HorizontalAlignment="Center"/>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <!-- Trạng thái Online -->
                                            <DataTrigger Binding="{Binding Status}" Value="Online">
                                                <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource StatusOnlineBg}"/>
                                                <Setter TargetName="StatusText" Property="Foreground" Value="{DynamicResource StatusOnlineText}"/>
                                            </DataTrigger>
                                            <!-- Trạng thái Offline -->
                                            <DataTrigger Binding="{Binding Status}" Value="Offline">
                                                <Setter TargetName="StatusBadge" Property="Background" Value="{DynamicResource StatusOfflineBg}"/>
                                                <Setter TargetName="StatusText" Property="Foreground" Value="{DynamicResource StatusOfflineText}"/>
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Binding="{Binding IP}" Width="120">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Content" Value="{DynamicResource Camera_GridHeader_IP}" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding Recording}" Width="90">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Content" Value="{DynamicResource Camera_GridHeader_RECORDING}" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Binding="{Binding Uptime}" Width="70">
                                <DataGridTextColumn.HeaderStyle>
                                    <Style TargetType="DataGridColumnHeader" BasedOn="{StaticResource {x:Type DataGridColumnHeader}}">
                                        <Setter Property="Content" Value="{DynamicResource Camera_GridHeader_UPTIME}" />
                                    </Style>
                                </DataGridTextColumn.HeaderStyle>
                            </DataGridTextColumn>
                        </DataGrid.Columns>
                    </DataGrid>

                    <DockPanel Grid.Row="2" Margin="0,5,0,0">
                       <TextBlock x:Name="FooterText" Text="{DynamicResource Camera_Label_Showing0Of0}" Foreground="{DynamicResource TextPrimary}" FontSize="11" VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                            <Button Content="&lt;" Style="{StaticResource PageButtonStyle}" Click="PageButton_Click"/>

                            <ItemsControl x:Name="PaginationItemsControl">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Button Content="{Binding Content}" 
                                                Tag="{Binding}"
                                                Click="PageButton_Click">
                                            <Button.Style>
                                                <Style TargetType="Button" BasedOn="{StaticResource PageButtonStyle}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource ButtonBg}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                        </Button>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="&gt;" Style="{StaticResource PageButtonStyle}" Click="PageButton_Click"/>
                        </StackPanel>
                    </DockPanel>
                </Grid>


	            <Thumb x:Name="InternalResizeThumb" Width="12" Height="12" Cursor="SizeNWSE" VerticalAlignment="Bottom" HorizontalAlignment="Right" Background="Transparent">
                    <Thumb.Template>
                        <ControlTemplate>
                            <Path Data="M 12,0 L 12,12 L 0,12 Z" Fill="#888" Opacity="0.5"/>
                        </ControlTemplate>
                    </Thumb.Template>
                </Thumb>

		    </Grid>
	    </Border>
     </Grid>
</UserControl>