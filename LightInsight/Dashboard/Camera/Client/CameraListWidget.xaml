<UserControl x:Class="LightInsight.Dashboard.Camera.Client.CameraListWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             mc:Ignorable="d" 
             Height="300"
			 Width="1080"
             x:Name="MyWidget"
             d:DesignWidth="1400"
             d:DesignHeight="300">

	<UserControl.Resources>
		<Style x:Key="TabButtonStyle" TargetType="RadioButton">
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="RadioButton">
						<Border x:Name="bg" Background="Transparent" CornerRadius="4" Padding="8,2">
							<ContentPresenter />
						</Border>
						<ControlTemplate.Triggers>
							<Trigger Property="IsChecked" Value="True">
								<Setter TargetName="bg" Property="Background" Value="#E8751A"/>
							</Trigger>
						</ControlTemplate.Triggers>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="FontSize" Value="11"/>
		</Style>
		<Style x:Key="PageButtonStyle" TargetType="Button">
			<Setter Property="Background" Value="#3E3E42"/>
			<Setter Property="Foreground" Value="White"/>
			<Setter Property="Width" Value="22"/>
			<Setter Property="Height" Value="22"/>
			<Setter Property="Margin" Value="2,0"/>
			<Setter Property="BorderThickness" Value="0"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Template">
				<Setter.Value>
					<ControlTemplate TargetType="Button">
						<Border Background="{TemplateBinding Background}" CornerRadius="2">
							<ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
						</Border>
					</ControlTemplate>
				</Setter.Value>
			</Setter>
			<Style.Triggers>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#505055"/>
				</Trigger>
			</Style.Triggers>
		</Style>
	</UserControl.Resources>

	<Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Width="{Binding RelativeSource={RelativeSource AncestorType=Canvas}, 
                    Path=ActualWidth, 
                    FallbackValue=900}">

		<Border.BorderBrush>
			<VisualBrush>
				<VisualBrush.Visual>
					<Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
				</VisualBrush.Visual>
			</VisualBrush>
		</Border.BorderBrush>

		<Grid>
			<Border Background="#3E3E42" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1"
                    Height="30" VerticalAlignment="Top" Padding="10,0,0,0" CornerRadius="6,6,0,0">
				<TextBlock Text="Camera Analytics Summary" Foreground="White" FontSize="14" VerticalAlignment="Center"/>
			</Border>

			<Button x:Name="DeleteButton" Content="X" Width="30" Height="23" HorizontalAlignment="Right" 
                    VerticalAlignment="Top" Margin="0,3,3,0" FontSize="16" Click="DeleteWidget_Click"
                    Panel.ZIndex="10"/>

			<Grid Margin="10,35,10,10">
				<Grid.RowDefinitions>
					<RowDefinition Height="Auto"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="Auto"/>
				</Grid.RowDefinitions>

				<DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,10">
					<StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
						<RadioButton Content="All (8)" Style="{StaticResource TabButtonStyle}" IsChecked="True" Margin="0,0,5,0"/>
						<RadioButton Content="Online (6)" Style="{StaticResource TabButtonStyle}" Margin="0,0,5,0"/>
						<RadioButton Content="Offline (2)" Style="{StaticResource TabButtonStyle}"/>
					</StackPanel>

					<Border DockPanel.Dock="Right" Background="#3E3E42" CornerRadius="4" Width="180" Height="22">
						<Grid>
							<TextBox x:Name="SearchBox" Background="Transparent" BorderThickness="0" Foreground="White" 
                                     VerticalContentAlignment="Center" Padding="5,0,25,0" FontSize="11" KeyDown="SearchBox_KeyDown"/>
							<TextBlock Text="🔍" 
							   Foreground="#888" 
							   HorizontalAlignment="Right" 
							   VerticalAlignment="Center" 
							   Margin="0,0,5,0" 
							   IsHitTestVisible="True" 
							   Cursor="Hand" 
							   MouseDown="SearchIcon_MouseDown"/>
						</Grid>
					</Border>
				</DockPanel>

				<DataGrid Grid.Row="1" Background="Transparent" Foreground="White" RowBackground="Transparent"
                          BorderThickness="0" GridLinesVisibility="None" AutoGenerateColumns="False"
                          CanUserAddRows="False" IsReadOnly="True" RowHeaderWidth="0"
                          HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto" x:Name="CameraDataGrid">

					<DataGrid.Resources>
						<Style TargetType="DataGridColumnHeader">
							<Setter Property="Background" Value="Transparent"/>
							<Setter Property="Foreground" Value="#888"/>
							<Setter Property="FontSize" Value="10"/>
							<Setter Property="FontWeight" Value="SemiBold"/>
							<Setter Property="Padding" Value="5,5"/>
							<Setter Property="BorderThickness" Value="0,0,0,1"/>
							<Setter Property="BorderBrush" Value="#444"/>
						</Style>
					</DataGrid.Resources>

					<DataGrid.Columns>
						<DataGridTextColumn Header="ID" Binding="{Binding ID}" Width="80"/>
						<DataGridTextColumn Header="NAME" Binding="{Binding Name}" Width="*"/>
						<DataGridTemplateColumn Header="STATUS" Width="90">
							<DataGridTemplateColumn.CellTemplate>
								<DataTemplate>
									<Border Background="{Binding StatusColor}" CornerRadius="2" Padding="5,1">
										<TextBlock Text="{Binding Status}" Foreground="#4ADE80" FontSize="10" HorizontalAlignment="Center"/>
									</Border>
								</DataTemplate>
							</DataGridTemplateColumn.CellTemplate>
						</DataGridTemplateColumn>
						<DataGridTextColumn Header="IP" Binding="{Binding IP}" Width="110"/>
						<DataGridTextColumn Header="RECORDING" Binding="{Binding Recording}" Width="90"/>
						<DataGridTextColumn Header="UPTIME" Binding="{Binding Uptime}" Width="70"/>
					</DataGrid.Columns>
				</DataGrid>

				<DockPanel Grid.Row="2" Margin="0,5,0,0">
					<TextBlock Text="Showing 8 of 8" Foreground="#666" FontSize="11" VerticalAlignment="Center"/>

					<StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
						<Button Content="&lt;" 
            Style="{StaticResource PageButtonStyle}" 
            Click="PageButton_Click"/>

						<Button Content="1" x:Name="BtnPage1"
            Style="{StaticResource PageButtonStyle}" 
            Background="#E8751A" 
            Click="PageButton_Click"/>

						<Button Content="2" x:Name="BtnPage2"
            Style="{StaticResource PageButtonStyle}" 
            Click="PageButton_Click"/>

						<Button Content="&gt;" 
            Style="{StaticResource PageButtonStyle}" 
            Click="PageButton_Click"/>
					</StackPanel>
				</DockPanel>
			</Grid>
		</Grid>
	</Border>
</UserControl>