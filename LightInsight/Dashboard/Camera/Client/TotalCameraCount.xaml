<UserControl x:Class="LightInsight.Dashboard.Camera.Client.TotalCameraCount"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="130"
             Width="200">

    <Border Background="#2D2D30"
            BorderBrush="#444"
            BorderThickness="1"
            CornerRadius="6"
            Padding="10">

        <Grid>
			<Button x:Name="DeleteButton"
                Content="X"
                Width="15" 
                Height="15"
                MinWidth="0"   
                MinHeight="0"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                HorizontalContentAlignment="Center" 
                VerticalContentAlignment="Center"
                Padding="0" 
                FontSize="10"
                Click="DeleteWidget_Click"/>

			<StackPanel Margin="0 10 0 0">

                <TextBlock Text="Camera Online Count"
                           Foreground="White"
                           FontSize="14"
                           Margin="0 0 0 5"/>

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                    <TextBlock FontFamily="Segoe MDL2 Assets" 
                               Text="&#xE722;" 
                               FontSize="24" 
                               Foreground="#7DB8FF"
                               VerticalAlignment="Center"
                               Margin="0 0 10 0"/>

                    <TextBlock Text="150"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#7DB8FF"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Cameras"
                           Foreground="LightGray"/>

            </StackPanel>
        </Grid>
    </Border>
</UserControl>