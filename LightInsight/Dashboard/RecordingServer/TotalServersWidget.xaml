<UserControl x:Class="LightInsight.Dashboard.RecordingServer.TotalServersWidget"
             x:Name="RootWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Tag="2x2"
             Width="Auto" Height="Auto"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch"
             UseLayoutRounding="True"
             SnapsToDevicePixels="True">

    <Grid Margin="5,5,0,0">
        <Border x:Name="MainBorder"
                Background="{DynamicResource BgMain}"
                BorderThickness="1"
                CornerRadius="6">

            <!-- DASH BORDER -->
            <Border.BorderBrush>
                <VisualBrush Stretch="None">
                    <VisualBrush.Visual>
                        <Rectangle Stroke="#E8751A"
                                   StrokeDashArray="4 2"
                                   StrokeThickness="1"
                                   RadiusX="6" RadiusY="6"
                                   Width="{Binding ElementName=MainBorder, Path=ActualWidth}"
                                   Height="{Binding ElementName=MainBorder, Path=ActualHeight}"/>
                    </VisualBrush.Visual>
                </VisualBrush>
            </Border.BorderBrush>

            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="25"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <Grid Grid.Row="0" Background="{DynamicResource WidgetHeaderBg}">
                    <TextBlock Text="{DynamicResource Recording_Title_TotalServers}"
                               Foreground="{DynamicResource WidgetHeaderText}"
                               FontSize="14"
                               VerticalAlignment="Center"
                               Margin="10,0"/>
                    <Border Height="1"
                            VerticalAlignment="Bottom"
                            Background="{DynamicResource WidgetBorder}"/>

                    <Button x:Name="DeleteButton" 
        Content="X" 
        Width="20" Height="20" 
        MinWidth="20" MinHeight="20"
        MaxWidth="20" MaxHeight="20"
        HorizontalAlignment="Right" 
        VerticalAlignment="Top" 
        Margin="0,3,3,0"
        Padding="0"
        FontSize="12"
        FontWeight="Bold"
        Foreground="{DynamicResource TextPrimary}"
        Background="{DynamicResource ButtonBg}"
        BorderThickness="0"
        HorizontalContentAlignment="Center"
        VerticalContentAlignment="Center"
        Click="DeleteWidget_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="2"/>
                            </Style>
                        </Button.Resources>
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border x:Name="btnBorder"
                    
                    Background="{TemplateBinding Background}" 
                    BorderBrush="{TemplateBinding BorderBrush}" 
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="3">
                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>

                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#55FFFFFF"/>
                                    </Trigger>

                                    <Trigger Property="IsPressed" Value="True">
                                        <Setter TargetName="btnBorder" Property="Background" Value="#33FFFFFF"/>
                                        <Setter Property="Foreground" Value="#DDD"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>
                </Grid>

                <!-- CONTENT -->
                <Grid Grid.Row="1" Margin="10">

                    <!-- SCALE -->
                    <Viewbox Stretch="Uniform">
                        <StackPanel Width="200">

                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Path Data="M 3,4 H 21 A 2,2 0 0 1 23,6 V 10 A 2,2 0 0 1 21,12 H 3 A 2,2 0 0 1 1,10 V 6 A 2,2 0 0 1 3,4 Z 
                                            M 3,14 H 21 A 2,2 0 0 1 23,16 V 20 A 2,2 0 0 1 21,22 H 3 A 2,2 0 0 1 1,20 V 16 A 2,2 0 0 1 3,14 Z 
                                            M 17,8 H 19 
                                            M 17,18 H 19"
                                      Stroke="#75A9F9"
                                      StrokeThickness="2"
                                      Width="24"
                                      Height="24"
                                      Margin="0,0,10,0"/>

                                <TextBlock x:Name="CountText"
                                           Text="13"
                                           FontSize="32"
                                           FontWeight="Bold"
                                           Foreground="#75A9F9"/>
                            </StackPanel>

                            <TextBlock Text="{DynamicResource Recording_Label_TotalServers}"
                                       Foreground="{DynamicResource TextPrimary}"
                                       FontSize="16"
                                       Margin="0,5,0,0"/>

                        </StackPanel>
                    </Viewbox>

                    <!-- RESIZE -->
                    <Thumb x:Name="InternalResizeThumb"
                           Width="12"
                           Height="12"
                           Cursor="SizeNWSE"
                           VerticalAlignment="Bottom"
                           HorizontalAlignment="Right"
                           Background="Transparent">
                        <Thumb.Template>
                            <ControlTemplate>
                                <Path Data="M 12,0 L 12,12 L 0,12 Z"
                                      Fill="#888"
                                      Opacity="0.5"/>
                            </ControlTemplate>
                        </Thumb.Template>
                    </Thumb>

                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>