<UserControl x:Class="LightInsight.Dashboard.RecordingServer.ServersOfflineCountWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="150"
             Width="320">

    <Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0">
        <Border.BorderBrush>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.BorderBrush>

        <Grid>
            <Border Background="#3E3E42"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,0,0,1"
                    Height="25"
                    VerticalAlignment="Top"
                    Padding="10,0,0,0"
                    CornerRadius="6,6,0,0">
                <TextBlock Text="Servers Offline Count"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Border>

            <Button x:Name="DeleteButton"
                    Content="X"
                    Width="30" Height="23"
                    MinWidth="0" MinHeight="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    FontSize="16"
                    Click="DeleteWidget_Click"/>

            <StackPanel Margin="4 40 0 0">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M 12,18 A 2,2 0 0 1 12,22 A 2,2 0 0 1 12,18 Z M 8,14 A 8,8 0 0 1 16,14 M 4,10 A 14,14 0 0 1 20,10 M 2,2 L 22,22" 
                          Stroke="#FF6B6B" StrokeThickness="2.5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                          Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" Margin="0 0 10 0"/>

                    <TextBlock x:Name="CountText" Text="1"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#FF6B6B"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Servers Offline" Foreground="#AAAAAA" FontSize="16" Margin="0,0,0,10"/>

                <StackPanel Orientation="Horizontal">
                    <Path Data="M 2,8 L 6,14 L 10,10 L 16,16 M 12,16 L 16,16 L 16,12" 
                          Stroke="#EF4444" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                          Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0 0 6 0"/>

                    <TextBlock x:Name="TrendText" Text="50% vs last period"
                               Foreground="#EF4444" 
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>