<UserControl x:Class="LightInsight.Dashboard.RecordingServer.ServersOnlineCountWidget"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="150"
             Width="300">

    <Border Background="#2D2D30"
            BorderThickness="1"
            CornerRadius="6"
            Padding="0">
        <Border.BorderBrush>
            <VisualBrush>
                <VisualBrush.Visual>
                    <Rectangle Stroke="#E8751A"
                               StrokeDashArray="4 2"
                               StrokeThickness="1"
                               RadiusX="6" RadiusY="6"
                               Width="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualWidth}"
                               Height="{Binding RelativeSource={RelativeSource AncestorType=Border}, Path=ActualHeight}"/>
                </VisualBrush.Visual>
            </VisualBrush>
        </Border.BorderBrush>

        <Grid>
            <Border Background="#3E3E42"
                    BorderBrush="#33FFFFFF"
                    BorderThickness="0,0,0,1"
                    Height="25"
                    VerticalAlignment="Top"
                    Padding="10,0,0,0"
                    CornerRadius="6,6,0,0">
                <TextBlock Text="Servers Online Count"
                           Foreground="White"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Border>

            <Button x:Name="DeleteButton"
                    Content="X"
                    Width="30" Height="23"
                    MinWidth="0" MinHeight="0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Margin="0,2,2,0"
                    FontSize="16"
                    Click="DeleteWidget_Click"/>

            <StackPanel Margin="4 40 0 0">

                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Path Data="M 3,4 H 21 A 2,2 0 0 1 23,6 V 10 A 2,2 0 0 1 21,12 H 3 A 2,2 0 0 1 1,10 V 6 A 2,2 0 0 1 3,4 Z M 3,14 H 21 A 2,2 0 0 1 23,16 V 20 A 2,2 0 0 1 21,22 H 3 A 2,2 0 0 1 1,20 V 16 A 2,2 0 0 1 3,14 Z M 17,8 H 19 M 17,18 H 19" 
                          Stroke="#2ECC71" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                          Width="24" Height="24" Stretch="Uniform" VerticalAlignment="Center" Margin="0 0 10 0"/>

                    <TextBlock x:Name="CountText" Text="12"
                               FontSize="32"
                               FontWeight="Bold"
                               Foreground="#2ECC71"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <TextBlock Text="Servers Online"
                           Foreground="LightGray"
                           FontSize="16"/>

                <StackPanel Orientation="Horizontal">
                    <Path Data="M2,14 L8,8 L12,12 L18,4 M14,4 L18,4 L18,8" 
                          Stroke="#2ECC71" StrokeThickness="2" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round" 
                          Width="12" Height="12" Stretch="Uniform" VerticalAlignment="Center" Margin="0 0 6 0"/>

                    <TextBlock x:Name="TrendText" Text="0% vs last period"
                               Foreground="#2ECC71" 
                               FontSize="12"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>