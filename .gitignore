*.[Pp]ublish.xml
*.azurePubxml

# Microsoft Azure
*.build.csdef

# Windows Store app package directory
AppPackages/

# NuGet packages
packages/
*.nupkg
*.snupkg
*.nuget.props
*.nuget.targets

# NuGet Symbol Packages
*.symbols.nupkg

# Azure Functions
bin/
obj/

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Backup & temporary files
*.bak
*.tmp
*.temp

# JetBrains Rider
.idea/

# VS Code
.vscode/

# Node modules (nếu project có frontend)
node_modules/

# Environment variables
.env
.env.*
